    <!-- Modal Aluno -->
    <div class="modal-overlay" id="m-aluno">
        <div class="modal"><div class="modal-header"><h3>🎒 Cadastrar Aluno</h3><div style="display:flex;align-items:center;gap:8px;"><button class="btn btn-green btn-sm" onclick="closeM('m-aluno');go('lista-turma');">📋 Lista</button><button class="modal-close" onclick="closeM('m-aluno')">×</button></div></div>
            <div class="form-row"><div class="form-group"><label class="form-label">Número na Turma</label><input class="form-control" id="aluno-numero" type="number" placeholder="Ex: 01" min="1" max="60"><div class="form-hint">Número sequencial na lista de chamada</div></div><div class="form-group"><label class="form-label">Matrícula</label><input class="form-control" id="aluno-matricula" placeholder="Ex: 2025001"></div></div>
            <div class="form-row c1"><div class="form-group"><label class="form-label">Nome Completo <span class="req">*</span></label><input class="form-control" id="aluno-nome" placeholder="Nome completo do aluno"></div></div>
            <div class="form-row"><div class="form-group"><label class="form-label">Data de Nascimento</label><input class="form-control" id="aluno-nascimento" type="date"></div><div class="form-group"><label class="form-label">Gênero</label><select class="form-control" id="aluno-genero"><option>Masculino</option><option>Feminino</option><option>Outro</option></select></div></div>
            <div class="form-row"><div class="form-group"><label class="form-label">Turma <span class="req">*</span></label><select class="form-control" id="aluno-turma"><option value="">Selecione a turma</option></select></div><div class="form-group"><label class="form-label">Responsável</label><input class="form-control" id="aluno-responsavel" placeholder="Pai, mãe ou responsável"></div></div>
            <div class="form-row"><div class="form-group"><label class="form-label">Telefone</label><input class="form-control" id="aluno-telefone" placeholder="(00) 99999-9999"></div><div class="form-group"><label class="form-label">E-mail</label><input class="form-control" id="aluno-email" type="email" placeholder="email@exemplo.com"></div></div>
            <div class="form-row c1"><div class="form-group"><label class="form-label">Observações</label><textarea class="form-control" id="aluno-observacoes" rows="2" placeholder="Necessidades especiais..."></textarea></div></div>
            <div class="modal-footer"><button class="btn btn-green btn-sm" onclick="closeM('m-aluno');go('lista-turma');" style="margin-right:auto;">📋 Ver Lista</button><button class="btn btn-outline" onclick="closeM('m-aluno')">Cancelar</button><button class="btn btn-green" onclick="salvarAluno()">💾 Salvar</button></div>
