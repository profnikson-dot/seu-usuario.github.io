
<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
    <title>CorrigePro — Sistema de Correção de Provas</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>

    <!-- ══════════ BOTÃO MENU HAMBÚRGUER ══════════ -->
    <button class="menu-toggle" id="menuToggle" onclick="toggleMenu()">☰</button>
    <div class="menu-overlay" id="menuOverlay" onclick="toggleMenu()"></div>

  <!-- ══════════ LOGIN ══════════ -->
<div id="login-screen">
    <div class="login-bg">
        <div class="login-blob lb1"></div>
        <div class="login-blob lb2"></div>
        <div class="login-blob lb3"></div>
    </div>
    <div class="login-card">
        <div class="login-logo">
            <div class="l-icon">🎓</div>
            <h1>CorrigePro</h1>
            <p>Sistema Inteligente de Correção de Provas</p>
            
            <!-- ══════════ NOVO TEXTO - PREFEITURA E SISAM ══════════ -->
            <div style="margin-top:14px;padding-top:14px;border-top:1px solid rgba(255,255,255,0.1);text-align:center;">
                <div style="font-size:11px;color:var(--text3);text-transform:uppercase;letter-spacing:1px;font-weight:600;margin-bottom:4px;">Prefeitura Municipal de</div>
                <div style="font-size:15px;font-weight:800;background:linear-gradient(135deg,#60a5fa,#3b82f6);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;letter-spacing:0.3px;">São Sebastião da Boa Vista</div>
                <div style="font-size:10px;color:var(--text3);text-transform:uppercase;letter-spacing:1.2px;font-weight:600;margin:4px 0 2px;">Secretaria Municipal de Educação</div>
                <div style="font-size:13px;font-weight:800;background:linear-gradient(135deg,#60a5fa,#3b82f6);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;letter-spacing:0.5px;margin-top:4px;">SISAM 2026</div>
            </div>
            <!-- ══════════ FIM DO NOVO TEXTO ══════════ -->
            
        </div>
        <div class="login-tabs">
            <button class="login-tab active" onclick="setLTab('admin')">🛠️ Administrador</button>
            <button class="login-tab" onclick="setLTab('user')">👤 Usuário</button>
        </div>
        <div class="lf-group"><label>Usuário</label><input id="lu" class="lf-input" type="text" placeholder="Digite seu usuário" autocomplete="off"></div>
        <div class="lf-group"><label>Senha</label><input id="lp" class="lf-input" type="password" placeholder="••••••••"></div>
        <button class="btn-login" onclick="doLogin()">Entrar no Sistema →</button>
        
        <!-- ══════════ RODAPÉ DO LOGIN — DESENVOLVEDORES ══════════ -->
        <div style="margin-top:18px;padding-top:16px;border-top:1px solid rgba(255,255,255,0.1);text-align:center;">
            <div style="font-size:10px;color:var(--text3);text-transform:uppercase;letter-spacing:1.5px;font-weight:700;margin-bottom:6px;">Desenvolvido por</div>
            <div style="font-size:14px;font-weight:800;background:var(--grad-blue);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;letter-spacing:0.5px;">Professor Nixo Auli & Jorge Antonio</div>
        </div>
    </div>
</div>

    <!-- ══════════ APP ══════════ -->
    <div id="app">
        <div class="sidebar" id="sidebar">
            <div class="sb-brand">
                <div class="sb-logo">🎓</div>
                <div class="sb-brand-name">Corrije<span>Pro</span></div>
            </div>
            <div class="sb-nav">
                <div id="adm-sb">
                    <div class="sb-section">Principal</div>
                    <div class="sb-item active" onclick="go('dashboard')" data-p="dashboard"><span class="sb-ico">🏠</span> Dashboard</div>
                    <div class="sb-section">Cadastros</div>
                    <div class="sb-item" onclick="go('escola')" data-p="escola"><span class="sb-ico">🏫</span> Escolas</div>
                    <div class="sb-item" onclick="go('turmas')" data-p="turmas"><span class="sb-ico">👥</span> Turmas</div>
                    <div class="sb-item" onclick="go('alunos')" data-p="alunos"><span class="sb-ico">🎒</span> Alunos</div>
                    <div class="sb-item" onclick="go('lista-turma')" data-p="lista-turma"><span class="sb-ico">📋</span> Lista por Turma</div>
                    <div class="sb-section">Avaliações</div>
                    <div class="sb-item" onclick="go('prova-upload')" data-p="prova-upload"><span class="sb-ico">📤</span> Cadastrar Prova</div>
                    <div class="sb-item" onclick="go('provas')" data-p="provas"><span class="sb-ico">📑</span> Provas</div>
                    <div class="sb-item" onclick="go('gabarito')" data-p="gabarito"><span class="sb-ico">✅</span> Gabarito</div>
                    <div class="sb-item" onclick="go('gabaritos')" data-p="gabaritos"><span class="sb-ico">📋</span> Gabaritos</div>
                    <div class="sb-section">IA & Correção</div>
                    <div class="sb-item" onclick="go('corrigir-ia')" data-p="corrigir-ia"><span class="sb-ico">🤖</span> Corrigir com IA <span class="sb-badge">IA</span></div>
                    <div class="sb-item" onclick="go('correcao-texto')" data-p="correcao-texto"><span class="sb-ico">✍️</span> Texto com IA <span class="sb-badge">IA</span></div>
                    <div class="sb-item" onclick="abrirCamera()"><span class="sb-ico">📱</span> Câmera do Celular</div>
                    <div class="sb-item" onclick="abrirArquivo()"><span class="sb-ico">📂</span> Escolher Arquivo</div>
                    <div class="sb-section">Resultados</div>
                    <div class="sb-item" onclick="go('resultados')" data-p="resultados"><span class="sb-ico">🏆</span> Resultados</div>
                    <div class="sb-item" onclick="go('rel-turma')" data-p="rel-turma"><span class="sb-ico">📊</span> Rel. por Turma</div>
                    <div class="sb-item" onclick="go('rel-aluno')" data-p="rel-aluno"><span class="sb-ico">👤</span> Rel. por Aluno</div>
                    <div class="sb-item" onclick="go('rel-escola')" data-p="rel-escola"><span class="sb-ico">🏫</span> Rel. por Escola CSV </div>
                    <div class="sb-section">Sistema</div>
                    <div class="sb-item" onclick="go('config')" data-p="config"><span class="sb-ico">⚙️</span> Configurações</div>
                </div>
                <div id="usr-sb" style="display:none;">
                    <div class="sb-section">Menu</div>
                    <div class="sb-item active" onclick="go('u-dashboard')" data-p="u-dashboard"><span class="sb-ico">🏠</span> Início</div>
                    <div class="sb-item" onclick="go('u-escola')" data-p="u-escola"><span class="sb-ico">🏫</span> Escola</div>
                    <div class="sb-item" onclick="go('u-turmas')" data-p="u-turmas"><span class="sb-ico">👥</span> Turmas</div>
                    <div class="sb-item" onclick="go('u-alunos')" data-p="u-alunos"><span class="sb-ico">🎒</span> Alunos</div>
                    <div class="sb-item" onclick="go('lista-turma')" data-p="lista-turma"><span class="sb-ico">📋</span> Lista por Turma</div>
                    <div class="sb-section">Consultas</div>
                    <div class="sb-item" onclick="go('u-resultados')" data-p="u-resultados"><span class="sb-ico">🏆</span> Resultados</div>
                    <div class="sb-item" onclick="go('u-relatorios')" data-p="u-relatorios"><span class="sb-ico">📊</span> Relatórios</div>
                    <div class="sb-section">IA</div>
                    <div class="sb-item" onclick="go('correcao-texto')" data-p="correcao-texto"><span class="sb-ico">✍️</span> Correção Texto IA <span class="sb-badge">IA</span></div>
                    <div class="sb-item" onclick="abrirCamera()"><span class="sb-ico">📱</span> Câmera</div>
                </div>
            </div>
            <div class="sb-footer">
                <div class="sb-user">
                    <div class="sb-avatar" id="sb-avatar">A</div>
                    <div style="flex:1;min-width:0;">
                        <div class="sb-uname" id="sb-uname">Administrador</div>
                        <div class="sb-urole" id="sb-urole">Administrador do Sistema</div>
                    </div>
                </div>
                <button class="sb-logout" onclick="doLogout()">🚪 Sair do Sistema</button>
            </div>
        </div>

        <div class="content">
            <!-- ═══ DASHBOARD ═══ -->
            <div class="page active" id="page-dashboard">
                <div class="page-header">
                    <div><div class="page-title">🏠 Dashboard</div><p class="page-sub">Visão geral do sistema</p></div>
                    <div class="page-actions">
                        <button class="btn btn-outline" onclick="abrirCamera()">📱 Câmera</button>
                        <button class="btn btn-primary" onclick="go('corrigir-ia')">🤖 Corrigir com IA</button>
                    </div>
                </div>
                <div class="stats-grid">
                    <div class="stat-card blue"><div class="stat-top"><div class="stat-icon blue">🏫</div></div><div><div class="stat-val" id="totalEscolas">0</div><div class="stat-label">Escolas</div></div></div>
                    <div class="stat-card green"><div class="stat-top"><div class="stat-icon green">👥</div></div><div><div class="stat-val" id="totalTurmas">0</div><div class="stat-label">Turmas</div></div></div>
                    <div class="stat-card orange"><div class="stat-top"><div class="stat-icon orange">🎒</div></div><div><div class="stat-val" id="totalAlunos">0</div><div class="stat-label">Alunos</div></div></div>
                    <div class="stat-card purple"><div class="stat-top"><div class="stat-icon purple">📄</div></div><div><div class="stat-val" id="totalProvas">0</div><div class="stat-label">Provas</div></div></div>
                </div>
                <div class="ai-hero">
                    <div class="ai-hero-icon">🤖</div>
                    <div class="ai-hero-text"><h3>Ferramentas de Inteligência Artificial</h3><p>Corrija cartões resposta, scaneie com câmera e avalie textos com o Gemini AI</p></div>
                    <div class="ai-hero-actions">
                        <button class="btn btn-purple" onclick="go('corrigir-ia')">🤖 Corrigir com IA</button>
                        <button class="btn btn-outline" onclick="go('correcao-texto')">✍️ Correção de Texto</button>
                    </div>
                </div>
                <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-bottom:18px;">
                    <div class="ai-feature-btn afb-purple" onclick="go('corrigir-ia')"><div class="af-ico">🤖</div><div class="af-title">Corrigir com IA</div><div class="af-sub">Detecção automática</div></div>
                    <div class="ai-feature-btn afb-blue" onclick="abrirCamera()"><div class="af-ico">📱</div><div class="af-title">Câmera do Celular</div><div class="af-sub">Scan em tempo real</div></div>
                    <div class="ai-feature-btn afb-green" onclick="abrirArquivo()"><div class="af-ico">📂</div><div class="af-title">Escolher Arquivo</div><div class="af-sub">Imagem do cartão</div></div>
                    <div class="ai-feature-btn afb-red" onclick="go('correcao-texto')"><div class="af-ico">✍️</div><div class="af-title">Correção de Texto</div><div class="af-sub">Coesão e coerência</div></div>
                </div>
                <div class="g2">
                    <div class="card">
                        <div class="card-header">
                            <div class="card-title">📊 Desempenho por Turma</div>
                            <span class="badge badge-green" id="total-turmas-badge">0 turmas</span>
                        </div>
                        <div id="grafico-desempenho" style="min-height:200px;display:flex;align-items:center;justify-content:center;padding:20px;">
                            <div style="text-align:center;color:var(--text3);">
                                <div style="font-size:40px;margin-bottom:10px;">📊</div>
                                <p>Carregando dados de desempenho...</p>
                            </div>
                        </div>
                    </div>
                    <div class="card">
                        <div class="card-header"><div class="card-title">⚡ Últimas Correções</div><span class="badge badge-green">● Ao Vivo</span></div>
                        <div class="table-wrap"><table><thead><tr><th>Aluno</th><th>Prova</th><th>Nota</th><th>Status</th></tr></thead><tbody id="ultimas-correcoes"><tr><td colspan="4" style="text-align:center;padding:30px;color:var(--text3);">Carregando...</td></tr></tbody></table></div>
                    </div>
                </div>
            </div>

            <!-- ═══ ESCOLA ═══ -->
            <div class="page" id="page-escola">
                <div class="page-header">
                    <div><div class="page-title">🏫 Escolas</div><p class="page-sub">Gerencie as unidades de ensino cadastradas</p></div>
                    <div class="page-actions">
                        <div class="search-wrap"><span class="search-ico">🔍</span><input type="text" placeholder="Buscar escola..." oninput="filtrarTabela(this,'tb-escola')"></div>
                        <button class="btn btn-primary" onclick="openM('m-escola')">+ Nova Escola</button>
                    </div>
                </div>
                <div class="card">
                    <div class="table-wrap"><table>
                        <thead><tr><th>#</th><th>Nome da Escola</th><th>Município</th><th>INEP</th><th>Diretor(a)</th><th>Turmas</th><th>Alunos</th><th>Ações</th></tr></thead>
                        <tbody id="tb-escola"><tr><td colspan="8" style="text-align:center;padding:30px;color:var(--text3);">Carregando...</td></tr></tbody>
                    </table></div>
                </div>
            </div>

            <!-- ═══ TURMAS ═══ -->
            <div class="page" id="page-turmas">
                <div class="page-header">
                    <div><div class="page-title">👥 Turmas</div><p class="page-sub">1º Ano ao 9º Ano do Ensino Fundamental</p></div>
                    <div class="page-actions">
                        <div class="search-wrap"><span class="search-ico">🔍</span><input type="text" placeholder="Buscar turma..." oninput="filtrarTabela(this,'tb-turmas')"></div>
                        <select class="form-control" style="width:140px;padding:8px 12px;font-size:12px;" onchange="filtrarSerie(this)">
                            <option value="">Todas as séries</option>
                            <option>1º Ano</option><option>2º Ano</option><option>3º Ano</option>
                            <option>4º Ano</option><option>5º Ano</option><option>6º Ano</option>
                            <option>7º Ano</option><option>8º Ano</option><option>9º Ano</option>
                        </select>
                        <button class="btn btn-primary" onclick="openM('m-turma')">+ Nova Turma</button>
                    </div>
                </div>
                <div class="card">
                    <div class="table-wrap"><table>
                        <thead><tr><th>#</th><th>Turma</th><th>Série</th><th>Turno</th><th>Escola</th><th>Professor(a)</th><th>Alunos</th><th>Ações</th></tr></thead>
                        <tbody id="tb-turmas"><tr><td colspan="8" style="text-align:center;padding:30px;color:var(--text3);">Carregando...</td></tr></tbody>
                    </table></div>
                </div>
            </div>

            <!-- ═══ LISTA POR TURMA ═══ -->
            <div class="page" id="page-lista-turma">
                <div class="page-header">
                    <div><div class="page-title">📋 Lista de Alunos por Turma</div><p class="page-sub">Emissão oficial da lista de chamada</p></div>
                    <div class="page-actions"><button class="btn btn-outline" onclick="window.print()">🖨️ Imprimir</button><button class="btn btn-green">📥 Exportar PDF</button></div>
                </div>
                <div class="card">
                    <div class="form-row c3">
                        <div class="form-group"><label class="form-label">Escola</label><select class="form-control" id="lista-escola" onchange="carregarTurmasLista(this.value)"><option value="">Selecione a escola</option></select></div>
                        <div class="form-group"><label class="form-label">Série</label><select class="form-control" id="lista-serie"><option value="">Todas</option><option>1º Ano</option><option>2º Ano</option><option>3º Ano</option><option>4º Ano</option><option>5º Ano</option><option>6º Ano</option><option>7º Ano</option><option>8º Ano</option><option>9º Ano</option></select></div>
                        <div class="form-group"><label class="form-label">Turma</label><select class="form-control" id="lista-turma"><option value="">Selecione a turma</option></select></div>
                    </div>
                    <button class="btn btn-primary" onclick="gerarListaTurma()">🔍 Gerar Lista</button>
                </div>
                <div class="card" id="lista-resultado"><div style="text-align:center;padding:20px;color:var(--text3);">Selecione os filtros e clique em "Gerar Lista"</div></div>
            </div>

            <!-- ═══ ALUNOS ═══ -->
            <div class="page" id="page-alunos">
                <div class="page-header">
                    <div><div class="page-title">🎒 Alunos</div><p class="page-sub">1º ao 9º Ano — Filtrar por escola, turma e série</p></div>
                    <div class="page-actions">
                        <select class="form-control" style="width:160px;padding:8px 11px;font-size:12px;" id="filtro-escola-alunos" onchange="filtrarAlunosPorEscola(this.value)">
                            <option value="">Todas as escolas</option>
                        </select>
                        <select class="form-control" style="width:140px;padding:8px 11px;font-size:12px;" id="filtro-turma-alunos" onchange="carregarAlunos(document.getElementById('filtro-escola-alunos').value)">
                            <option value="">Todas as turmas</option>
                        </select>
                        <div class="search-wrap"><span class="search-ico">🔍</span><input type="text" placeholder="Buscar aluno..." oninput="filtrarTabela(this,'tb-alunos')"></div>
                        <select class="form-control" style="width:120px;padding:8px 11px;font-size:12px;" id="filtro-serie-alunos" onchange="filtrarAlunosPorSerie(this.value)">
                            <option value="">Todas séries</option>
                            <option>1º Ano</option><option>2º Ano</option><option>3º Ano</option>
                            <option>4º Ano</option><option>5º Ano</option><option>6º Ano</option>
                            <option>7º Ano</option><option>8º Ano</option><option>9º Ano</option>
                        </select>
                        <button class="btn btn-green" onclick="go('lista-turma')">📋 Lista</button>
                        <button class="btn btn-outline" onclick="exportarAlunosCSV()">📤 CSV</button>
                        <button class="btn btn-primary" onclick="openM('m-aluno')">+ Novo Aluno</button>
                    </div>
                </div>
                <div class="card">
                    <div class="table-wrap"><table>
                        <thead><tr><th>Nº</th><th>Matrícula</th><th>Nome Completo</th><th>Série</th><th>Turma</th><th>Escola</th><th>Data Nasc.</th><th>Ações</th></tr></thead>
                        <tbody id="tb-alunos"><tr><td colspan="8" style="text-align:center;padding:30px;color:var(--text3);">Carregando...</td></tr></tbody>
                    </table></div>
                </div>
            </div>

            <!-- ═══ CADASTRAR PROVA ═══ -->
            <div class="page" id="page-prova-upload">
                <div class="page-header"><div><div class="page-title"> Cadastrar Prova</div><p class="page-sub">Configure os parâmetros da avaliação</p></div></div>
                <div class="g2">
                    <div class="card">
                        <div class="card-header"><div class="card-title"> Informações</div></div>
                        <div class="form-row c1"><div class="form-group"><label class="form-label">Título <span class="req">*</span></label><input class="form-control" id="prova-titulo" placeholder="Ex: 3º Bimestre — Matemática"></div></div>
                        <div class="form-row"><div class="form-group"><label class="form-label">Disciplina <span class="req">*</span></label><select class="form-control" id="prova-disciplina"><option>Matemática</option><option>Português</option><option>Ciências</option><option>História</option><option>Geografia</option><option>Inglês</option></select></div><div class="form-group"><label class="form-label">Bimestre</label><select class="form-control" id="prova-bimestre"><option>1º Bimestre e 2º Bimestre</option><option>3º Bimestre e 4º Bimestre</option></select></div></div>
                        <div class="form-row"><div class="form-group"><label class="form-label">Escola <span class="req">*</span></label><select class="form-control" id="prova-escola" onchange="carregarTurmasProva()"><option value="">Selecione a escola</option></select></div><div class="form-group"><label class="form-label">Série <span class="req">*</span></label><select class="form-control" id="prova-serie" onchange="atualizarInfoAlts()"><option>1º Ano</option><option>2º Ano</option><option>3º Ano</option><option>4º Ano</option><option>5º Ano</option><option>6º Ano</option><option>7º Ano</option><option>8º Ano</option><option>9º Ano</option></select></div></div>
                        <div class="form-row"><div class="form-group"><label class="form-label">Turma</label><select class="form-control" id="prova-turma"><option value="">Selecione a turma</option></select></div><div class="form-group"><label class="form-label">Data</label><input class="form-control" id="prova-data" type="date"></div></div>
                        <div class="form-row"><div class="form-group"><label class="form-label">Nº de Questões</label><select class="form-control" id="prova-questoes"><option>10</option><option>15</option><option selected>20</option><option>25</option><option>30</option></select></div><div class="form-group"><label class="form-label">Nota Máxima</label><input class="form-control" id="prova-nota" type="number" value="10"></div></div>
                        <div id="info-alts" style="padding:10px 14px;background:rgba(139,92,246,.08);border:1px solid rgba(139,92,246,.25);border-radius:8px;font-size:12px;color:#a78bfa;font-weight:600;margin-bottom:6px;">ℹ️ 1º Ano — Gabarito com 3 alternativas: A, B, C</div>
                    </div>
                    <div class="card">
                        <div class="card-header"><div class="card-title"> Arquivo</div></div>
                        <div class="upload-zone" onclick="simUpload()" style="margin-bottom:14px;"><div class="uz-ico"></div><p><strong>Clique para enviar</strong> ou arraste aqui</p><p class="uz-hint">PDF, DOCX, PNG — máx. 50MB</p></div>
                        <div id="up-ok" style="display:none;padding:12px;background:rgba(16,185,129,.08);border:1px solid rgba(16,185,129,.2);border-radius:8px;margin-bottom:14px;font-size:13px;color:var(--green);">✅ <strong>arquivo_enviado.pdf</strong> — enviado!</div>
                        <div class="btn-group"><button class="btn btn-green btn-full" onclick="salvarProva()"> Salvar</button><button class="btn btn-primary btn-full" onclick="go('gabarito')">➡️ Gabarito</button></div>
                    </div>
                </div>
            </div>

            <!-- ═══ GABARITO ═══ -->
            <div class="page" id="page-gabarito">
                <div class="page-header"><div><div class="page-title">✅ Cadastrar Gabarito</div><p class="page-sub">1º Ano: A,B,C &nbsp;|&nbsp; 2º ao 9º Ano: A,B,C,D</p></div></div>
                <div class="card">
                    <div class="form-row c3">
                        <div class="form-group"><label class="form-label">Prova <span class="req">*</span></label><select class="form-control" id="gab-prova" onchange="buildGabGrid()"><option value="">Selecione...</option></select></div>
                        <div class="form-group"><label class="form-label">Série <span class="req">*</span></label><select class="form-control" id="gab-serie" onchange="buildGabGrid()"><option value="1">1º Ano — A, B, C</option><option value="2" selected>2º Ano — A, B, C, D</option><option value="3">3º Ano — A, B, C, D</option><option value="4">4º Ano — A, B, C, D</option><option value="5">5º Ano — A, B, C, D</option><option value="6">6º Ano — A, B, C, D</option><option value="7">7º Ano — A, B, C, D</option><option value="8">8º Ano — A, B, C, D</option><option value="9">9º Ano — A, B, C, D</option></select></div>
                        <div class="form-group"><label class="form-label">Nº de Questões</label><select class="form-control" id="gab-total" onchange="buildGabGrid()"><option>10</option><option>15</option><option selected>20</option><option>25</option><option>30</option></select></div>
                    </div>
                    <div style="display:flex;gap:10px;flex-wrap:wrap;"><div style="padding:8px 14px;background:rgba(139,92,246,.1);border:1px solid rgba(139,92,246,.3);border-radius:8px;font-size:12px;font-weight:700;color:#a78bfa;">🔵 1º Ano — A, B, C</div><div style="padding:8px 14px;background:rgba(59,130,246,.1);border:1px solid rgba(59,130,246,.3);border-radius:8px;font-size:12px;font-weight:700;color:var(--blue);">🟦 2º ao 9º Ano — A, B, C, D</div></div>
                </div>
                <div class="card">
                    <div class="card-header"><div class="card-title">📝 Gabarito das Questões</div><div class="btn-group"><button class="btn btn-outline btn-sm" onclick="fillGabRand()">🎲 Teste</button><button class="btn btn-ghost btn-sm" onclick="clearGab()">🗑️ Limpar</button></div></div>
                    <div id="gab-label" style="font-size:11px;font-weight:700;color:var(--text2);margin-bottom:10px;"></div>
                    <div class="gab-grid" id="gab-grid"></div>
                    <div class="form-row c3" style="margin-top:18px;"><div class="form-group"><label class="form-label">Pts por Acerto</label><input class="form-control" type="number" value="0.5" step="0.1"></div><div class="form-group"><label class="form-label">Penalidade</label><select class="form-control"><option>Sem penalidade</option><option>-0.25</option><option>-0.5</option></select></div><div class="form-group"><label class="form-label">Questões Anuladas</label><input class="form-control" placeholder="Ex: 5, 12"></div></div>
                    <div class="btn-group"><button class="btn btn-green" onclick="saveGab()">💾 Salvar Gabarito</button><button class="btn btn-purple" onclick="go('corrigir-ia')">🤖 Corrigir com IA</button></div>
                </div>
            </div>

            <!-- ═══ CORRIGIR COM IA ═══ -->
            <div class="page" id="page-corrigir-ia">
                <div class="page-header"><div><div class="page-title">🤖 Corrigir com IA</div><p class="page-sub">Detecção e correção automática de cartões resposta</p></div></div>
                <div class="g2" style="margin-bottom:18px;">
                    <div class="card card-glow-blue" style="border-color:rgba(6,182,212,.3);">
                        <div class="card-header"><div class="card-title" style="color:var(--cyan);">📱 Câmera do Celular</div><span class="badge badge-cyan">Real-time</span></div>
                        <p style="font-size:13px;color:var(--text2);margin-bottom:14px;line-height:1.6;">Aponte a câmera para o cartão resposta. O sistema detecta as marcações com IA automaticamente.</p>
                        <div style="background:var(--bg2);border:1px solid var(--border);border-radius:10px;padding:26px;text-align:center;cursor:pointer;transition:all .25s;" onclick="abrirCamera()"><div style="font-size:50px;margin-bottom:8px;">📱</div><p style="color:var(--text2);font-size:13px;">Clique para abrir a câmera</p></div>
                        <button class="btn btn-lg btn-full" style="margin-top:12px;background:linear-gradient(135deg,var(--cyan),#0e7490);color:#fff;box-shadow:0 4px 14px rgba(6,182,212,.3);" onclick="abrirCamera()">📱 Abrir Câmera do Celular</button>
                    </div>
                    <div class="card card-glow-green">
                        <div class="card-header"><div class="card-title" style="color:var(--green);">📂 Escolher Arquivo</div><span class="badge badge-green">JPG / PNG</span></div>
                        <p style="font-size:13px;color:var(--text2);margin-bottom:14px;line-height:1.6;">Selecione uma foto do cartão resposta. A IA detecta e corrige as respostas automaticamente.</p>
                        <div class="upload-zone" onclick="abrirArquivo()" style="margin-bottom:10px;"><div class="uz-ico">📂</div><p><strong>Clique para escolher a imagem</strong></p><p class="uz-hint">JPG, PNG — máx. 20MB</p></div>
                        <div id="arq-preview" style="display:none;text-align:center;margin:8px 0;"><img id="img-prev" style="max-width:100%;max-height:180px;border-radius:8px;border:1px solid var(--border);" src="" alt=""></div>
                        <button class="btn btn-lg btn-full btn-green" onclick="abrirArquivo()">📂 Escolher Arquivo</button>
                        <input type="file" id="inp-arq" accept="image/*" style="display:none" onchange="processarArq(this)">
                    </div>
                </div>
                <div class="card">
                    <div class="card-header"><div class="card-title">⚙️ Configurações da Correção</div></div>
                    <div class="form-row c3">
                        <div class="form-group"><label class="form-label">Prova <span class="req">*</span></label><select class="form-control" id="corrigir-prova"><option value="">Selecione...</option></select></div>
                        <div class="form-group"><label class="form-label">Série</label><select class="form-control" id="corrigir-serie"><option value="">Selecione...</option><option value="1º Ano">1º Ano</option><option value="2º Ano">2º Ano</option><option value="3º Ano">3º Ano</option><option value="4º Ano">4º Ano</option><option value="5º Ano">5º Ano</option><option value="6º Ano">6º Ano</option><option value="7º Ano">7º Ano</option><option value="8º Ano">8º Ano</option><option value="9º Ano">9º Ano</option></select></div>
                        <div class="form-group"><label class="form-label">Aluno</label><select class="form-control" id="corrigir-aluno"><option value="">Selecione...</option></select></div>
                    </div>
                    <div style="display:flex;gap:14px;flex-wrap:wrap;"><label style="display:flex;align-items:center;gap:7px;font-size:13px;cursor:pointer;color:var(--text2);"><input type="checkbox" checked> Detecção automática</label><label style="display:flex;align-items:center;gap:7px;font-size:13px;cursor:pointer;color:var(--text2);"><input type="checkbox" checked> OCR para nome/matrícula</label><label style="display:flex;align-items:center;gap:7px;font-size:13px;cursor:pointer;color:var(--text2);"><input type="checkbox" checked> Calcular nota automaticamente</label></div>
                </div>
                <div id="ia-result" style="display:none;">
                    <div class="card card-glow-green">
                        <div class="card-header"><div class="card-title" style="color:var(--green);">🤖 Resultado — Correção por IA</div><div class="btn-group"><span class="badge badge-green">✅ Processado</span><span class="badge badge-gray" id="confianca-badge">0% conf.</span></div></div>
                        <div class="g2" style="margin-bottom:14px;">
                            <div>
                                <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:12px;font-size:13px;"><div style="background:var(--surface2);border-radius:8px;padding:9px;"><div style="color:var(--text3);font-size:9px;font-weight:700;margin-bottom:3px;">ALUNO</div><div style="font-weight:700;" id="ia-aluno">—</div></div><div style="background:var(--surface2);border-radius:8px;padding:9px;"><div style="color:var(--text3);font-size:9px;font-weight:700;margin-bottom:3px;">TURMA</div><div style="font-weight:700;" id="ia-turma">—</div></div></div>
                                <div style="font-size:11px;color:var(--text3);font-weight:700;margin-bottom:7px;text-transform:uppercase;letter-spacing:.5px;">Respostas detectadas:</div>
                                <div style="display:flex;flex-wrap:wrap;gap:4px;" id="ia-resp"></div>
                            </div>
                            <div style="display:flex;flex-direction:column;align-items:center;justify-content:center;background:var(--bg2);border-radius:12px;padding:22px;text-align:center;">
                                <div style="font-size:68px;font-weight:900;color:var(--green);line-height:1;" id="ia-nota">0</div>
                                <div style="font-size:13px;color:var(--text2);margin-top:4px;">Nota Final</div>
                                <span class="badge badge-green" style="margin-top:10px;font-size:12px;padding:5px 16px;" id="ia-status">AGUARDANDO</span>
                                <button class="btn btn-orange btn-sm" style="margin-top:10px;" onclick="abrirCorrecaoManual()">✏️ Correção Manual</button>
                            </div>
                        </div>
                        <div style="display:grid;grid-template-columns:repeat(10,1fr);gap:5px;margin-bottom:14px;" id="ia-comp"></div>
                        <div class="btn-group"><button class="btn btn-green btn-sm" onclick="salvarCorrecao()">💾 Salvar</button><button class="btn btn-primary btn-sm" onclick="go('resultados')">📊 Resultados</button><button class="btn btn-purple btn-sm" onclick="processarComIA(document.getElementById('ia-ultima-imagem')?.value)">🔄 Próximo</button></div>
                        <input type="hidden" id="ia-ultima-imagem">
                    </div>
                </div>
            </div>

            <!-- ═══ CORREÇÃO DE TEXTO IA ═══ -->
            <div class="page" id="page-correcao-texto">
                <div class="page-header"><div><div class="page-title">✍️ Correção de Texto com IA</div><p class="page-sub">Gemini AI avalia coerência, coesão, gramática e critérios textuais</p></div></div>
                <div class="g2">
                    <div>
                        <div class="card">
                            <div class="card-header"><div class="card-title">📥 Enviar Texto</div></div>
                            <div class="tab-nav"><button class="tab-btn active" onclick="switchTab(0,this)">📱 Câmera</button><button class="tab-btn" onclick="switchTab(1,this)">📂 Arquivo</button><button class="tab-btn" onclick="switchTab(2,this)">⌨️ Digitar</button></div>
                            <div class="tab-c" id="tabc-0"><div style="background:var(--bg2);border:1px solid var(--border);border-radius:10px;padding:26px;text-align:center;cursor:pointer;margin-bottom:12px;" onclick="abrirCamera()"><div style="font-size:46px;margin-bottom:8px;">📱</div><p style="color:var(--text2);font-size:13px;">Fotografe a redação do aluno</p></div><button class="btn btn-full btn-lg" style="background:linear-gradient(135deg,var(--cyan),#0e7490);color:#fff;box-shadow:0 4px 14px rgba(6,182,212,.3);" onclick="abrirCamera()">📱 Abrir Câmera</button></div>
                            <div class="tab-c" id="tabc-1" style="display:none;"><div class="upload-zone" onclick="document.getElementById('inp-txt').click()" style="margin-bottom:12px;"><div class="uz-ico">📸</div><p><strong>Escolher foto da redação</strong></p><p class="uz-hint">JPG, PNG, PDF</p></div><input type="file" id="inp-txt" accept="image/*,application/pdf" style="display:none" onchange="prevTexto(this)"><div id="txt-img-prev" style="display:none;text-align:center;margin-bottom:12px;"><img id="txt-img" style="max-width:100%;max-height:200px;border-radius:8px;border:1px solid var(--border);" src="" alt=""></div><button class="btn btn-full btn-green" onclick="document.getElementById('inp-txt').click()">📂 Escolher Arquivo</button></div>
                            <div class="tab-c" id="tabc-2" style="display:none;"><div class="form-group" style="margin-bottom:12px;"><label class="form-label">Texto do Aluno</label><textarea class="form-control" id="txt-aluno" rows="8" placeholder="Cole ou digite o texto aqui..."></textarea></div></div>
                            <div style="margin-top:16px;padding-top:16px;border-top:1px solid var(--border);">
                                <div class="form-row"><div class="form-group"><label class="form-label">Aluno</label><select class="form-control" id="txt-aluno-select"><option value="">Selecione...</option></select></div><div class="form-group"><label class="form-label">Série</label><select class="form-control" id="txt-serie"><option>1º Ano</option><option>2º Ano</option><option>3º Ano</option><option>4º Ano</option><option>5º Ano</option><option>6º Ano</option><option>7º Ano</option><option>8º Ano</option><option>9º Ano</option></select></div></div>
                                <div style="margin-bottom:14px;"><label class="form-label" style="margin-bottom:8px;">Critérios de Avaliação</label><div style="display:flex;flex-direction:column;gap:7px;margin-top:6px;"><label style="display:flex;align-items:center;gap:8px;font-size:13px;cursor:pointer;color:var(--text2);"><input type="checkbox" checked> Coerência e Coesão</label><label style="display:flex;align-items:center;gap:8px;font-size:13px;cursor:pointer;color:var(--text2);"><input type="checkbox" checked> Adequação ao Tema</label><label style="display:flex;align-items:center;gap:8px;font-size:13px;cursor:pointer;color:var(--text2);"><input type="checkbox" checked> Ortografia e Gramática</label><label style="display:flex;align-items:center;gap:8px;font-size:13px;cursor:pointer;color:var(--text2);"><input type="checkbox" checked> Riqueza Vocabular</label></div></div>
                                <button class="btn btn-full btn-lg btn-purple" onclick="avaliarTexto()">🤖 Avaliar com Gemini AI</button>
                            </div>
                        </div>
                    </div>
                    <div>
                        <div id="txt-waiting" class="card" style="min-height:320px;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;"><div style="font-size:60px;margin-bottom:14px;opacity:.35;">🤖</div><h3 style="font-size:16px;margin-bottom:8px;">Aguardando texto</h3><p style="font-size:13px;color:var(--text2);">Envie a foto ou cole o texto e clique em <strong>"Avaliar com Gemini AI"</strong></p></div>
                        <div id="txt-loading" style="display:none;" class="card"><div style="text-align:center;padding:32px;"><div class="spinner" style="margin-bottom:14px;"></div><p style="font-size:14px;font-weight:700;">Gemini AI processando...</p><p style="font-size:12px;color:var(--text2);margin-top:5px;">Analisando critérios textuais</p><div class="progress" style="margin-top:14px;height:4px;"><div class="progress-fill pf-purple" id="txt-pb" style="width:0%;transition:width .15s;"></div></div></div></div>
                        <div id="txt-res" style="display:none;" class="card card-glow-purple">
                            <div class="card-header"><div class="card-title" style="color:#a78bfa;">🤖 Avaliação Gemini AI</div><span class="badge badge-purple">IA</span></div>
                            <div style="display:flex;align-items:center;gap:16px;margin-bottom:16px;padding:16px;background:var(--bg2);border-radius:10px;"><div><div style="font-size:60px;font-weight:900;line-height:1;color:#a78bfa;" id="txt-nota">0</div><div style="font-size:12px;color:var(--text2);margin-top:3px;">Nota Final</div></div><div style="flex:1;"><div style="font-weight:700;font-size:15px;margin-bottom:8px;" id="txt-aluno-nome">—</div><span class="badge badge-green" id="txt-status">AGUARDANDO</span></div></div>
                            <div class="ai-criteria-grid"><div class="ai-crit"><div class="ai-crit-name">Coerência e Coesão</div><div class="ai-crit-val" id="c-coe">0</div><div class="progress"><div class="progress-fill pf-purple" id="b-coe" style="width:0%;"></div></div></div><div class="ai-crit"><div class="ai-crit-name">Adequação ao Tema</div><div class="ai-crit-val" id="c-tema">0</div><div class="progress"><div class="progress-fill pf-purple" id="b-tema" style="width:0%;"></div></div></div><div class="ai-crit"><div class="ai-crit-name">Ortografia e Gramática</div><div class="ai-crit-val" id="c-ort">0</div><div class="progress"><div class="progress-fill pf-purple" id="b-ort" style="width:0%;"></div></div></div><div class="ai-crit"><div class="ai-crit-name">Riqueza Vocabular</div><div class="ai-crit-val" id="c-voc">0</div><div class="progress"><div class="progress-fill pf-purple" id="b-voc" style="width:0%;"></div></div></div></div>
                            <div class="ai-feedback-box"><strong style="color:#a78bfa;">📝 Feedback:</strong><br><br><span id="txt-fb">Aguardando avaliação...</span></div>
                            <div class="btn-group" style="margin-top:14px;"><button class="btn btn-green btn-sm" onclick="salvarAvaliacaoTexto()">💾 Salvar</button><button class="btn btn-outline btn-sm" onclick="window.print()">🖨️</button><button class="btn btn-purple btn-sm" onclick="avaliarTexto()">🔄 Reavaliar</button></div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ═══ GABARITOS LIST ═══ -->
            <div class="page" id="page-gabaritos">
                <div class="page-header"><div><div class="page-title">📋 Gabaritos</div></div><div class="page-actions"><button class="btn btn-primary" onclick="go('gabarito')">+ Novo Gabarito</button></div></div>
                <div class="card"><div class="table-wrap"><table><thead><tr><th>#</th><th>Prova</th><th>Série</th><th>Questões</th><th>Alternativas</th><th>Criado</th><th>Ações</th></tr></thead><tbody id="tb-gabaritos"><tr><td colspan="7" style="text-align:center;padding:30px;color:var(--text3);">Carregando...</td></tr></tbody></table></div></div>
            </div>

            <!-- ═══ PROVAS ═══ -->
            <div class="page" id="page-provas">
                <div class="page-header"><div><div class="page-title">📑 Provas</div></div><div class="page-actions"><button class="btn btn-primary" onclick="go('prova-upload')">+ Nova Prova</button></div></div>
                <div class="card"><div class="table-wrap"><table><thead><tr><th>#</th><th>Título</th><th>Série</th><th>Turma</th><th>Data</th><th>Status</th><th>Ações</th></tr></thead><tbody id="tb-provas"><tr><td colspan="7" style="text-align:center;padding:30px;color:var(--text3);">Carregando...</td></tr></tbody></table></div></div>
            </div>

            <!-- ═══ RESULTADOS ═══ -->
            <div class="page" id="page-resultados">
                <div class="page-header">
                    <div>
                        <div class="page-title">🏆 Resultados</div>
                        <p class="page-sub">Notas, desempenho e análise visual</p>
                    </div>
                    <div class="page-actions">
                        <button class="btn btn-outline no-print" onclick="window.print()">🖨️ Imprimir</button>
                        <button class="btn btn-green no-print" onclick="exportarResultadosFiltrados()">📥 Excel</button>
                    </div>
                </div>

                <!-- FILTROS -->
                <div class="card no-print" style="margin-bottom:16px;">
                    <div class="form-row c3">
                        <div class="form-group">
                            <label class="form-label">Escola</label>
                            <select class="form-control" id="filtro-escola" onchange="carregarTurmasPorEscola(this.value)">
                                <option value="">Todas as escolas</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Série</label>
                            <select class="form-control" id="filtro-serie" onchange="carregarResultadosComFiltros()">
                                <option value="">Todas as séries</option>
                                <option value="1º Ano">1º Ano</option>
                                <option value="2º Ano">2º Ano</option>
                                <option value="3º Ano">3º Ano</option>
                                <option value="4º Ano">4º Ano</option>
                                <option value="5º Ano">5º Ano</option>
                                <option value="6º Ano">6º Ano</option>
                                <option value="7º Ano">7º Ano</option>
                                <option value="8º Ano">8º Ano</option>
                                <option value="9º Ano">9º Ano</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Turma</label>
                            <select class="form-control" id="filtro-turma" onchange="carregarResultadosComFiltros()">
                                <option value="">Todas as turmas</option>
                            </select>
                        </div>
                    </div>
                    <div style="display:flex;gap:8px;flex-wrap:wrap;margin-top:8px;">
                        <button class="btn btn-primary btn-sm" onclick="carregarResultadosComFiltros()">🔍 Filtrar</button>
                        <button class="btn btn-outline btn-sm" onclick="limparFiltrosResultados()">✕ Limpar Filtros</button>
                    </div>
                </div>

                <!-- CARDS DE ESTATÍSTICAS -->
                <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:16px;">
                    <div style="background:var(--surface);border:1px solid var(--border);border-radius:var(--r);padding:14px;text-align:center;">
                        <div style="font-size:26px;font-weight:800;color:var(--blue);" id="res-total-filtrado">0</div>
                        <div style="font-size:11px;color:var(--text2);">Total de Alunos</div>
                    </div>
                    <div style="background:var(--surface);border:1px solid rgba(16,185,129,.3);border-radius:var(--r);padding:14px;text-align:center;">
                        <div style="font-size:26px;font-weight:800;color:var(--green);" id="res-Habilidades-filtrado">0</div>
                        <div style="font-size:11px;color:var(--text2);">Adquiriu as Habilidades</div>
                    </div>
                    <div style="background:var(--surface);border:1px solid rgba(245,158,11,.3);border-radius:var(--r);padding:14px;text-align:center;">
                        <div style="font-size:26px;font-weight:800;color:var(--orange);" id="res-recuperacao-filtrado">0</div>
                        <div style="font-size:11px;color:var(--text2);">Recomposição da Aprendizagem</div>
                    </div>
                    <div style="background:var(--surface);border:1px solid rgba(139,92,246,.3);border-radius:var(--r);padding:14px;text-align:center;">
                        <div style="font-size:26px;font-weight:800;color:#a78bfa;" id="res-media-filtrado">0</div>
                        <div style="font-size:11px;color:var(--text2);">Média Geral</div>
                    </div>
                </div>

                <!-- GRÁFICOS DE CONCEITOS -->
                <div class="conceito-graficos" style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:16px;">
                    <!-- Gráfico de Barras -->
                    <div class="card">
                        <div class="card-header">
                            <div class="card-title">📊 Distribuição por Conceito</div>
                            <span class="badge badge-blue">Barras</span>
                        </div>
                        <div id="conceito-barras" style="display:flex;flex-direction:column;gap:12px;padding:8px 0;">
                            <div>
                                <div style="display:flex;justify-content:space-between;font-size:13px;margin-bottom:4px;">
                                    <span>🔴 Baixo (até 40%)</span>
                                    <span style="font-weight:700;color:#ef4444;" id="conceito-baixo-count">0</span>
                                </div>
                                <div class="progress" style="height:20px;border-radius:10px;background:var(--bg2);">
                                    <div class="progress-fill" style="width:0%;background:linear-gradient(90deg,#ef4444,#dc2626);border-radius:10px;transition:width 0.8s ease;" id="conceito-baixo-bar"></div>
                                </div>
                            </div>
                            <div>
                                <div style="display:flex;justify-content:space-between;font-size:13px;margin-bottom:4px;">
                                    <span>🟠 Médio Baixo (41% - 60%)</span>
                                    <span style="font-weight:700;color:#f59e0b;" id="conceito-medio-baixo-count">0</span>
                                </div>
                                <div class="progress" style="height:20px;border-radius:10px;background:var(--bg2);">
                                    <div class="progress-fill" style="width:0%;background:linear-gradient(90deg,#f59e0b,#d97706);border-radius:10px;transition:width 0.8s ease;" id="conceito-medio-baixo-bar"></div>
                                </div>
                            </div>
                            <div>
                                <div style="display:flex;justify-content:space-between;font-size:13px;margin-bottom:4px;">
                                    <span>🔵 Médio Alto (61% - 80%)</span>
                                    <span style="font-weight:700;color:#3b82f6;" id="conceito-medio-alto-count">0</span>
                                </div>
                                <div class="progress" style="height:20px;border-radius:10px;background:var(--bg2);">
                                    <div class="progress-fill" style="width:0%;background:linear-gradient(90deg,#3b82f6,#2563eb);border-radius:10px;transition:width 0.8s ease;" id="conceito-medio-alto-bar"></div>
                                </div>
                            </div>
                            <div>
                                <div style="display:flex;justify-content:space-between;font-size:13px;margin-bottom:4px;">
                                    <span>🟢 Alto (acima de 80%)</span>
                                    <span style="font-weight:700;color:#10b981;" id="conceito-alto-count">0</span>
                                </div>
                                <div class="progress" style="height:20px;border-radius:10px;background:var(--bg2);">
                                    <div class="progress-fill" style="width:0%;background:linear-gradient(90deg,#10b981,#059669);border-radius:10px;transition:width 0.8s ease;" id="conceito-alto-bar"></div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Gráfico Donut -->
                    <div class="card">
                        <div class="card-header">
                            <div class="card-title">🍩 Distribuição Percentual</div>
                            <span class="badge badge-purple">Donut</span>
                        </div>
                        <div style="display:flex;align-items:center;justify-content:center;padding:10px 0;">
                            <div style="position:relative;width:200px;height:200px;" id="donut-container">
                                <canvas id="donut-chart" width="200" height="200"></canvas>
                                <div style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);text-align:center;">
                                    <div style="font-size:12px;color:var(--text3);">Total</div>
                                    <div style="font-size:24px;font-weight:900;color:var(--text);" id="donut-total">0</div>
                                </div>
                            </div>
                            <div style="margin-left:20px;display:flex;flex-direction:column;gap:8px;font-size:12px;">
                                <div><span style="display:inline-block;width:16px;height:16px;border-radius:4px;background:#ef4444;vertical-align:middle;margin-right:8px;"></span> Baixo: <strong id="donut-baixo-pct">0%</strong></div>
                                <div><span style="display:inline-block;width:16px;height:16px;border-radius:4px;background:#f59e0b;vertical-align:middle;margin-right:8px;"></span> Médio Baixo: <strong id="donut-medio-baixo-pct">0%</strong></div>
                                <div><span style="display:inline-block;width:16px;height:16px;border-radius:4px;background:#3b82f6;vertical-align:middle;margin-right:8px;"></span> Médio Alto: <strong id="donut-medio-alto-pct">0%</strong></div>
                                <div><span style="display:inline-block;width:16px;height:16px;border-radius:4px;background:#10b981;vertical-align:middle;margin-right:8px;"></span> Alto: <strong id="donut-alto-pct">0%</strong></div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- TABELA DE RESULTADOS -->
                <div class="card">
                    <div class="card-header">
                        <div class="card-title">📋 Lista de Alunos</div>
                        <span class="badge badge-gray" id="total-alunos-tabela">0 alunos</span>
                    </div>
                    <div class="table-wrap">
                        <table>
                            <thead>
                                <tr>
                                    <th>Pos.</th>
                                    <th>Nº</th>
                                    <th>Nome</th>
                                    <th>Série</th>
                                    <th>Acertos</th>
                                    <th>%</th>
                                    <th>Conceito</th>
                                    <th>Nota</th>
                                    <th>Status</th>
                                    <th>Ações</th>
                                </tr>
                            </thead>
                            <tbody id="tb-resultados-filtrado">
                                <tr>
                                    <td colspan="10" style="text-align:center;padding:30px;color:var(--text3);">Carregando...</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- ═══ RELATÓRIOS ═══ -->
            <div class="page" id="page-rel-turma">
                <div class="page-header"><div><div class="page-title">📊 Relatório por Turma</div></div><div class="page-actions"><button class="btn btn-outline" onclick="window.print()">🖨️ Imprimir</button><button class="btn btn-green" onclick="exportarRelatorio()">📥 PDF</button></div></div>
                <div class="stats-grid"><div class="stat-card blue"><div class="stat-top"><div class="stat-icon blue">👥</div></div><div><div class="stat-val" id="rel-total-alunos">0</div><div class="stat-label">Total Alunos</div></div></div><div class="stat-card green"><div class="stat-top"><div class="stat-icon green">✅</div></div><div><div class="stat-val" id="rel-Habilidades">0</div><div class="stat-label">Adquiriu as Habilidades</div></div></div><div class="stat-card orange"><div class="stat-top"><div class="stat-icon orange">⚠️</div></div><div><div class="stat-val" id="rel-recuperacao">0</div><div class="stat-label">Recomposição da Aprendizagem</div></div></div><div class="stat-card purple"><div class="stat-top"><div class="stat-icon purple">📊</div></div><div><div class="stat-val" id="rel-media">0</div><div class="stat-label">Média</div></div></div></div>
                <div class="card"><div class="card-header"><div class="card-title">📈 Distribuição de Notas</div></div><div class="chart-bars" id="dist-notas"><div class="chart-bar-item"><div class="chart-bar-val" id="d0-2">0</div><div class="chart-bar" style="height:10px;background:linear-gradient(180deg,#ef4444,#b91c1c);"></div><div class="chart-bar-lbl">0–2</div></div><div class="chart-bar-item"><div class="chart-bar-val" id="d2-4">0</div><div class="chart-bar" style="height:10px;background:linear-gradient(180deg,#f59e0b,#b45309);"></div><div class="chart-bar-lbl">2–4</div></div><div class="chart-bar-item"><div class="chart-bar-val" id="d4-6">0</div><div class="chart-bar" style="height:10px;background:linear-gradient(180deg,#10b981,#047857);"></div><div class="chart-bar-lbl">4–6</div></div><div class="chart-bar-item"><div class="chart-bar-val" id="d6-8">0</div><div class="chart-bar" style="height:10px;background:linear-gradient(180deg,#3b82f6,#1d4ed8);"></div><div class="chart-bar-lbl">6–8</div></div><div class="chart-bar-item"><div class="chart-bar-val" id="d8-10">0</div><div class="chart-bar" style="height:10px;background:linear-gradient(180deg,#10b981,#047857);"></div><div class="chart-bar-lbl">8–10</div></div></div></div>
            </div>

            <div class="page" id="page-rel-aluno">
                <div class="page-header"><div><div class="page-title">👤 Relatório por Aluno</div></div><div class="page-actions"><button class="btn btn-outline" onclick="window.print()">🖨️</button><button class="btn btn-green" onclick="exportarRelatorioAluno()">📥 PDF</button></div></div>
                <div class="card"><div class="form-row c3"><div class="form-group"><label class="form-label">Aluno</label><select class="form-control" id="rel-aluno-select"><option value="">Selecione...</option></select></div><div class="form-group"><label class="form-label">Prova</label><select class="form-control" id="rel-prova-select"><option value="">Todas</option></select></div><div class="form-group" style="justify-content:flex-end;"><button class="btn btn-primary" style="margin-top:auto;" onclick="buscarRelatorioAluno()">🔍 Buscar</button></div></div></div>
                <div class="g2"><div class="card"><div class="card-header"><div class="card-title">📋 Histórico</div></div><div class="table-wrap"><table><thead><tr><th>Prova</th><th>Data</th><th>Nota</th><th>Status</th></tr></thead><tbody id="rel-aluno-historico"><tr><td colspan="4" style="text-align:center;padding:20px;color:var(--text3);">Selecione um aluno</td></tr></tbody></table></div></div><div class="card"><div class="card-header"><div class="card-title">📊 Desempenho</div></div><div class="chart-bars" style="height:100px;" id="rel-evolucao"><div style="text-align:center;padding:30px;color:var(--text3);width:100%;">Selecione um aluno</div></div></div></div>
            </div>

            <div class="page" id="page-rel-escola">
                <div class="page-header"><div><div class="page-title">🏫 Relatório por Escola</div></div><button class="btn btn-green page-actions" onclick="exportarRelatorioEscola()">📥 Exportar</button></div>
                <div class="card"><div class="table-wrap"><table><thead><tr><th>Escola</th><th>Turmas</th><th>Alunos</th><th>Média</th><th>Aprovação</th><th>Desempenho</th></tr></thead><tbody id="tb-rel-escola"><tr><td colspan="6" style="text-align:center;padding:30px;color:var(--text3);">Carregando...</td></tr></tbody></table></div></div>
            </div>

            <!-- ═══ CONFIG ═══ -->
            <div class="page" id="page-config">
                <div class="page-header"><div><div class="page-title">⚙️ Configurações</div></div><button class="btn btn-green" onclick="salvarConfiguracoes()">💾 Salvar</button></div>
                <div class="g2">
                    <div class="card"><div class="card-header"><div class="card-title">🏫 Instituição</div></div><div class="form-row c1"><div class="form-group"><label class="form-label">Secretaria</label><input class="form-control" id="config-secretaria" value="Secretaria Municipal de Educação"></div></div><div class="form-row c1"><div class="form-group"><label class="form-label">Município</label><input class="form-control" id="config-municipio" value="São sebastião da Boa Vista  — PA"></div></div></div>
                    <div class="card"><div class="card-header"><div class="card-title">🤖 IA & Scanner</div></div><div class="form-row c1"><div class="form-group"><label class="form-label">Modelo Gemini</label><select class="form-control" id="config-modelo"><option>gemini-1.5-flash</option><option>gemini-1.5-pro</option></select></div></div><div class="form-row c1"><div class="form-group"><label class="form-label">API Key Gemini</label><input class="form-control" id="config-api-key" type="password" placeholder="Chave opcional"></div></div></div>
                    <div class="card"><div class="card-header"><div class="card-title">📊 Escala de Notas</div></div><div class="form-row"><div class="form-group"><label class="form-label">Nota Máxima</label><input class="form-control" id="config-nota-max" type="number" value="10"></div><div class="form-group"><label class="form-label">Mínima (Aprovação)</label><input class="form-control" id="config-nota-min" type="number" value="5"></div></div></div>
                    <div class="card">
                        <div class="card-header"><div class="card-title">👥 Usuários</div><button class="btn btn-primary btn-sm" onclick="abrirModalUsuario()">+ Novo</button></div>
                        <div class="table-wrap"><table><thead><tr><th>Usuário</th><th>Perfil</th><th>Status</th><th>Ação</th></tr></thead><tbody id="tb-usuarios"><tr><td colspan="4" style="text-align:center;padding:20px;color:var(--text3);">Carregando...</td></tr></tbody></table></div>
                    </div>
                </div>
            </div>

            <!-- ═══ USER PAGES ═══ -->
            <div class="page" id="page-u-dashboard">
                <div class="page-header"><div><div class="page-title">🏠 Início</div><p class="page-sub">Portal do Usuário</p></div></div>
                <div class="stats-grid" style="grid-template-columns:repeat(3,1fr);"><div class="stat-card blue"><div class="stat-top"><div class="stat-icon blue">🏫</div></div><div><div class="stat-val" id="u-total-escolas">0</div><div class="stat-label">Escola</div></div></div><div class="stat-card green"><div class="stat-top"><div class="stat-icon green">👥</div></div><div><div class="stat-val" id="u-total-turmas">0</div><div class="stat-label">Turmas</div></div></div><div class="stat-card orange"><div class="stat-top"><div class="stat-icon orange">🎒</div></div><div><div class="stat-val" id="u-total-alunos">0</div><div class="stat-label">Alunos</div></div></div></div>
                <div class="card"><div class="card-header"><div class="card-title">📋 Provas Recentes</div></div><div class="table-wrap"><table><thead><tr><th>Prova</th><th>Série</th><th>Data</th><th>Status</th></tr></thead><tbody id="u-provas-recentes"><tr><td colspan="4" style="text-align:center;padding:20px;color:var(--text3);">Carregando...</td></tr></tbody></table></div></div>
            </div>
            <div class="page" id="page-u-escola"><div class="page-header"><div><div class="page-title">🏫 Escola</div></div><button class="btn btn-primary" onclick="openM('m-escola')">+ Nova</button></div><div class="card" id="u-escola-info"><div style="text-align:center;padding:20px;color:var(--text3);">Carregando...</div></div></div>
            <div class="page" id="page-u-turmas"><div class="page-header"><div><div class="page-title">👥 Turmas</div></div><button class="btn btn-primary" onclick="openM('m-turma')">+ Nova</button></div><div class="card"><div class="table-wrap"><table><thead><tr><th>Turma</th><th>Série</th><th>Professor</th><th>Alunos</th><th>Lista</th></tr></thead><tbody id="u-tb-turmas"><tr><td colspan="5" style="text-align:center;padding:20px;color:var(--text3);">Carregando...</td></tr></tbody></table></div></div></div>
            <div class="page" id="page-u-alunos"><div class="page-header"><div><div class="page-title">🎒 Alunos</div></div><button class="btn btn-primary" onclick="openM('m-aluno')">+ Novo</button></div><div class="card"><div class="table-wrap"><table><thead><tr><th>Nº</th><th>Matrícula</th><th>Nome</th><th>Série</th></tr></thead><tbody id="u-tb-alunos"><tr><td colspan="4" style="text-align:center;padding:20px;color:var(--text3);">Carregando...</td></tr></tbody></table></div></div></div>
            <div class="page" id="page-u-resultados"><div class="page-header"><div><div class="page-title">🏆 Resultados</div></div></div><div class="card"><div class="table-wrap"><table><thead><tr><th>Aluno</th><th>Prova</th><th>Nota</th><th>Status</th></tr></thead><tbody id="u-tb-resultados"><tr><td colspan="4" style="text-align:center;padding:20px;color:var(--text3);">Carregando...</td></tr></tbody></table></div></div></div>
            <div class="page" id="page-u-relatorios"><div class="page-header"><div><div class="page-title">📊 Relatórios</div></div><div class="page-actions"><button class="btn btn-outline" onclick="window.print()">🖨️</button><button class="btn btn-green">📥 PDF</button></div></div><div class="card"><div class="card-header"><div class="card-title">📊 Desempenho</div></div><div class="chart-bars" style="height:100px;" id="u-chart"><div style="text-align:center;padding:30px;color:var(--text3);width:100%;">Carregando dados...</div></div></div></div>
        </div>
    </div>

    <!-- ═══════════ CÂMERA MODAL ═══════════ -->
    <div class="cam-modal" id="cam-modal">
        <div class="cam-container">
            <div class="cam-header"><h3>📱 Scanner — Câmera do Celular</h3><button class="modal-close" onclick="fecharCamera()">×</button></div>
            <div class="cam-video-wrap"><video id="cam-video" autoplay playsinline></video><div class="cam-frame"><div class="cam-corner cc-tl"></div><div class="cam-corner cc-tr"></div><div class="cam-corner cc-bl"></div><div class="cam-corner cc-br"></div></div><div class="cam-scan-line"></div></div>
            <div class="cam-controls"><button class="btn btn-red" onclick="fecharCamera()">✕ Cancelar</button><button class="btn btn-outline" onclick="trocarCamera()" style="color:var(--cyan);border-color:var(--cyan);">🔄 Virar</button><button class="btn btn-green btn-lg" onclick="capturarFoto()">📸 Capturar</button></div>
            <p class="cam-hint">Enquadre o cartão resposta na moldura verde</p>
        </div>
        <canvas id="cam-canvas"></canvas>
    </div>

    <!-- ═══════════ MODAL CORREÇÃO MANUAL ═══════════ -->
    <div class="modal-overlay" id="m-correcao-manual">
        <div class="modal" style="max-width: 750px; width: 95vw;">
            <div class="modal-header">
                <h3>✏️ Correção Manual — <span id="cm-aluno-nome">Aluno</span></h3>
                <button class="modal-close" onclick="closeM('m-correcao-manual')">×</button>
            </div>
            <div class="correcao-aluno-info">
                <div class="info-item"><span class="label">Prova</span><strong id="cm-prova-titulo">—</strong></div>
                <div class="info-item"><span class="label">Série / Turma</span><strong id="cm-turma-info">—</strong></div>
                <div class="info-item"><span class="label">Data da Correção</span><strong id="cm-data-correcao">—</strong></div>
                <div class="info-item"><span class="label">Status</span><strong id="cm-status-atual">—</strong></div>
            </div>
            <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:8px;margin-bottom:12px;">
                <span style="font-size:13px;font-weight:700;color:var(--text2);">📝 Respostas do Aluno</span>
                <div class="btn-group">
                    <button class="btn btn-outline btn-sm" onclick="preencherGabaritoCM()">📋 Preencher com Gabarito</button>
                    <button class="btn btn-ghost btn-sm" onclick="limparRespostasCM()">🗑️ Limpar</button>
                </div>
            </div>
            <div id="cm-grid" class="correcao-manual-grid">
                <!-- Gerado dinamicamente -->
            </div>
            <div class="resumo-correcao">
                <div class="item"><div class="valor acertos" id="cm-acertos">0</div><div class="label">Acertos</div></div>
                <div class="item"><div class="valor erros" id="cm-erros">0</div><div class="label">Erros</div></div>
                <div class="item"><div class="valor nota" id="cm-nota">0,0</div><div class="label">Nota Final</div></div>
            </div>
            <div style="display:flex;gap:6px;flex-wrap:wrap;padding:10px 0;">
                <span id="cm-status-badge" class="badge badge-gray">AGUARDANDO</span>
                <span id="cm-porcentagem" style="font-size:12px;color:var(--text2);">0% de aproveitamento</span>
            </div>
            <div class="modal-footer">
                <button class="btn btn-outline" onclick="closeM('m-correcao-manual')">✕ Fechar</button>
                <button class="btn btn-green" onclick="salvarCorrecaoManual()">💾 Salvar Correção</button>
            </div>
        </div>
    </div>

    <!-- ═══════════ MODAL EDITAR ESCOLA ═══════════ -->
    <div class="modal-overlay" id="m-editar-escola">
        <div class="modal">
            <div class="modal-header">
                <h3>✏️ Editar Escola</h3>
                <button class="modal-close" onclick="closeM('m-editar-escola')">×</button>
            </div>
            <input type="hidden" id="editar-escola-id">
            <div class="form-row c1">
                <div class="form-group"><label class="form-label">Nome <span class="req">*</span></label><input class="form-control" id="editar-escola-nome" placeholder="Ex: E.E. Prof. João Ribeiro"></div>
            </div>
            <div class="form-row">
                <div class="form-group"><label class="form-label">INEP</label><input class="form-control" id="editar-escola-inep" placeholder="8 dígitos"></div>
                <div class="form-group"><label class="form-label">Município</label><input class="form-control" id="editar-escola-municipio" placeholder="Cidade"></div>
            </div>
            <div class="form-row">
                <div class="form-group"><label class="form-label">Estado</label><select class="form-control" id="editar-escola-estado"><option>PA</option></select></div>
                <div class="form-group"><label class="form-label">Telefone</label><input class="form-control" id="editar-escola-telefone" placeholder="(00) 0000-0000"></div>
            </div>
            <div class="form-row c1">
                <div class="form-group"><label class="form-label">Diretor(a)</label><input class="form-control" id="editar-escola-diretor" placeholder="Nome completo"></div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-outline" onclick="closeM('m-editar-escola')">Cancelar</button>
                <button class="btn btn-primary" onclick="salvarEdicaoEscola()">💾 Salvar Alterações</button>
            </div>
        </div>
    </div>

    <!-- ═══════════ MODAL EDITAR TURMA ═══════════ -->
    <div class="modal-overlay" id="m-editar-turma">
        <div class="modal">
            <div class="modal-header">
                <h3>✏️ Editar Turma</h3>
                <button class="modal-close" onclick="closeM('m-editar-turma')">×</button>
            </div>
            <input type="hidden" id="editar-turma-id">
            <div class="form-row">
                <div class="form-group"><label class="form-label">Escola <span class="req">*</span></label><select class="form-control" id="editar-turma-escola"><option value="">Selecione a escola</option></select></div>
                <div class="form-group"><label class="form-label">Ano Letivo</label><input class="form-control" id="editar-turma-ano" value="2025" type="number"></div>
            </div>
            <div class="form-row">
                <div class="form-group"><label class="form-label">Nome <span class="req">*</span></label><input class="form-control" id="editar-turma-nome" placeholder="Ex: 3ºA"></div>
                <div class="form-group"><label class="form-label">Série <span class="req">*</span></label><select class="form-control" id="editar-turma-serie"><option>1º Ano</option><option>2º Ano</option><option>3º Ano</option><option>4º Ano</option><option>5º Ano</option><option>6º Ano</option><option>7º Ano</option><option>8º Ano</option><option>9º Ano</option></select></div>
            </div>
            <div class="form-row">
                <div class="form-group"><label class="form-label">Turno</label><select class="form-control" id="editar-turma-turno"><option>Manhã</option><option>Tarde</option><option>Noite</option></select></div>
                <div class="form-group"><label class="form-label">Capacidade</label><input class="form-control" id="editar-turma-capacidade" type="number" placeholder="35"></div>
            </div>
            <div class="form-row c1">
                <div class="form-group"><label class="form-label">Professor(a)</label><input class="form-control" id="editar-turma-professor" placeholder="Nome do professor"></div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-outline" onclick="closeM('m-editar-turma')">Cancelar</button>
                <button class="btn btn-primary" onclick="salvarEdicaoTurma()">💾 Salvar Alterações</button>
            </div>
        </div>
    </div>

    <!-- ═══════════ MODAL EDITAR ALUNO ═══════════ -->
