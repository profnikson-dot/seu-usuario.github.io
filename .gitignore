    <!-- ═══════════ MODAL USUÁRIO ═══════════ -->
    <div class="modal-overlay" id="m-usuario">
        <div class="modal">
            <div class="modal-header">
                <h3>👤 Cadastrar Usuário</h3>
                <button class="modal-close" onclick="closeM('m-usuario')">×</button>
            </div>
            <div class="form-row c1">
                <div class="form-group">
                    <label class="form-label">Nome <span class="req">*</span></label>
                    <input class="form-control" id="usuario-nome" placeholder="Nome completo">
                </div>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">Usuário (Login) <span class="req">*</span></label>
                    <input class="form-control" id="usuario-username" placeholder="Ex: professor1">
                </div>
                <div class="form-group">
                    <label class="form-label">Senha <span class="req">*</span></label>
                    <input class="form-control" id="usuario-senha" type="password" placeholder="Mínimo 4 caracteres">
                </div>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">E-mail</label>
                    <input class="form-control" id="usuario-email" type="email" placeholder="email@exemplo.com">
                </div>
                <div class="form-group">
                    <label class="form-label">Perfil <span class="req">*</span></label>
                    <select class="form-control" id="usuario-perfil">
                        <option value="usuario">Usuário</option>
                        <option value="admin">Administrador</option>
                    </select>
                </div>
            </div>
            <div class="form-row c1">
                <div class="form-group">
                    <label class="form-label" style="display:flex;align-items:center;gap:8px;cursor:pointer;">
                        <input type="checkbox" id="usuario-ativo" checked style="width:16px;height:16px;">
                        Usuário ativo
                    </label>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-outline" onclick="closeM('m-usuario')">Cancelar</button>
                <button class="btn btn-green" onclick="salvarUsuario()">💾 Salvar Usuário</button>
            </div>
        </div>
    </div>

    <!-- TOAST -->
    <div class="toast-container" id="toast-c"></div>

    <script>
        // ============================================
        // CONFIGURAÇÃO DA API
        // ============================================
        const API_URL = 'https://adabee-sistema-3.onrender.com';
        let loginType = 'admin';
        let camStream = null;
        let camFacing = 'environment';
        let delTarget = null;
        let ultimaImagem = null;
        let correcaoManualData = {
            alunoId: null,
            alunoNome: '',
            provaId: null,
            provaTitulo: '',
            gabarito: [],
            respostasAluno: [],
            quantidade: 20,
            alternativas: ['A', 'B', 'C', 'D'],
            notaMaxima: 10,
            notaMinima: 5,
            valorPorQuestao: 0.5,
            serie: '1º Ano'
        };

        // ============================================
        // MENU TOGGLE
        // ============================================
        function toggleMenu() {
            const sidebar = document.getElementById('sidebar');
            const overlay = document.getElementById('menuOverlay');
            const toggle = document.getElementById('menuToggle');
            sidebar.classList.toggle('open');
            overlay.classList.toggle('show');
            toggle.classList.toggle('active');
            toggle.innerHTML = sidebar.classList.contains('open') ? '✕' : '☰';
        }

        // ============================================
        // LOGIN
        // ============================================
        function setLTab(t) {
            loginType = t;
            document.querySelectorAll('.login-tab').forEach((el, i) => {
                el.classList.toggle('active', (i === 0 && t === 'admin') || (i === 1 && t === 'user'));
            });
        }

        async function doLogin() {
            const u = document.getElementById('lu').value.trim();
            const p = document.getElementById('lp').value.trim();
            try {
                const response = await fetch(`${API_URL}/api/login`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ username: u, senha: p })
                });
                const data = await response.json();
                if (data.sucesso) {
                    startApp(data.perfil, data.usuario);
                } else {
                    showToast('❌ Usuário ou senha incorretos!', 'error');
                    shakeCard();
                }
            } catch (erro) {
                if ((loginType === 'admin' && u === 'admin' && p === 'admin') ||
                    (loginType === 'user' && (u === 'usuario' || u === 'professor1') && p === '123')) {
                    startApp(loginType, u);
                } else {
                    showToast('❌ Usuário ou senha incorretos!', 'error');
                    shakeCard();
                }
            }
        }

        function shakeCard() {
            const c = document.querySelector('.login-card');
            c.style.animation = 'none';
            setTimeout(() => c.style.animation = 'shake .4s ease', 10);
        }

        document.getElementById('lp').addEventListener('keydown', e => {
            if (e.key === 'Enter') doLogin();
        });

        function startApp(role, uname) {
            document.getElementById('login-screen').style.display = 'none';
            document.getElementById('app').style.display = 'flex';
            document.getElementById('sb-avatar').textContent = uname[0].toUpperCase();
            document.getElementById('sb-uname').textContent = uname;
            document.getElementById('sb-urole').textContent = role === 'admin' ? 'Administrador do Sistema' : 'Usuário do Sistema';
            const isAdmin = role === 'admin';
            document.getElementById('adm-sb').style.display = isAdmin ? 'block' : 'none';
            document.getElementById('usr-sb').style.display = isAdmin ? 'none' : 'block';
            go(isAdmin ? 'dashboard' : 'u-dashboard');
            buildGabGrid();
            carregarDados();
        }

        function doLogout() {
            document.getElementById('login-screen').style.display = 'flex';
            document.getElementById('app').style.display = 'none';
            document.getElementById('lu').value = '';
            document.getElementById('lp').value = '';
            fecharCamera();
        }

        // ============================================
        // NAVEGAÇÃO
        // ============================================
        function go(page) {
            document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
            const el = document.getElementById('page-' + page);
            if (el) el.classList.add('active');
            document.querySelectorAll('.sb-item').forEach(s => s.classList.toggle('active', s.dataset.p === page));

            if (page === 'escola') carregarEscolas();
            if (page === 'turmas') carregarTurmas();
            if (page === 'alunos') {
                const escolaId = document.getElementById('filtro-escola-alunos')?.value || '';
                carregarAlunos(escolaId);
            }
            if (page === 'provas') carregarProvas();
            if (page === 'dashboard') carregarDashboard();
            if (page === 'resultados') { carregarFiltrosResultados(); carregarResultadosComFiltros(); }
            if (page === 'gabaritos') carregarGabaritos();
            if (page === 'rel-turma' || page === 'rel-aluno' || page === 'rel-escola') carregarRelatorios();

            if (window.innerWidth <= 900) {
                const sidebar = document.getElementById('sidebar');
                const overlay = document.getElementById('menuOverlay');
                const toggle = document.getElementById('menuToggle');
                if (sidebar.classList.contains('open')) {
                    sidebar.classList.remove('open');
                    overlay.classList.remove('show');
                    toggle.classList.remove('active');
                    toggle.innerHTML = '☰';
                }
            }
        }

        // ============================================
        // FUNÇÃO PARA LISTAR ALUNOS DE UMA TURMA ESPECÍFICA
        // ============================================
        function verAlunosDaTurma(turmaId) {
            console.log('📋 Ver alunos da turma ID:', turmaId);
            
            // Ir para página de alunos
            go('alunos');
            
            // Aguardar a página carregar e então aplicar o filtro
            setTimeout(() => {
                const selectTurma = document.getElementById('filtro-turma-alunos');
                if (selectTurma) {
                    // Tentar encontrar e selecionar a turma
                    let encontrou = false;
                    for (let i = 0; i < selectTurma.options.length; i++) {
                        if (selectTurma.options[i].value == turmaId) {
                            selectTurma.selectedIndex = i;
                            encontrou = true;
                            break;
                        }
                    }
                    
                    if (encontrou) {
                        // Disparar evento para carregar os alunos
                        selectTurma.dispatchEvent(new Event('change'));
                        showToast('📋 Mostrando alunos da turma selecionada', 'success');
                    } else {
                        // Se não encontrou, tentar recarregar as turmas primeiro
                        const escolaId = document.getElementById('filtro-escola-alunos')?.value || '';
                        if (escolaId) {
                            carregarTurmasFiltro(escolaId, turmaId);
                        } else {
                            showToast('⚠️ Selecione uma escola primeiro para ver as turmas', 'warning');
                        }
                    }
                }
            }, 300);
        }
        
        // Função auxiliar para carregar turmas no filtro e selecionar uma específica
        async function carregarTurmasFiltro(escolaId, turmaIdSelecionada) {
            try {
                const response = await fetch(`${API_URL}/api/turmas?escola_id=${escolaId}`);
                const turmas = await response.json();
                const selectTurma = document.getElementById('filtro-turma-alunos');
                
                if (selectTurma && turmas && !turmas.erro) {
                    selectTurma.innerHTML = '<option value="">Todas as turmas</option>';
                    turmas.forEach(t => {
                        const opt = document.createElement('option');
                        opt.value = t.id;
                        opt.textContent = t.nome + ' - ' + (t.serie || '');
                        selectTurma.appendChild(opt);
                    });
                    
                    // Selecionar a turma específica
                    let encontrou = false;
                    for (let i = 0; i < selectTurma.options.length; i++) {
                        if (selectTurma.options[i].value == turmaIdSelecionada) {
                            selectTurma.selectedIndex = i;
                            encontrou = true;
                            break;
                        }
                    }
                    
                    if (encontrou) {
                        selectTurma.dispatchEvent(new Event('change'));
                        showToast('📋 Mostrando alunos da turma selecionada', 'success');
                    }
                }
            } catch (e) {
                console.error('Erro ao carregar turmas:', e);
            }
        }

        // ============================================
        // CARREGAR ESCOLAS NO FILTRO DE ALUNOS
        // ============================================
        async function carregarEscolasFiltroAlunos() {
            try {
                const response = await fetch(API_URL + '/api/escolas');
                const escolas = await response.json();
                const select = document.getElementById('filtro-escola-alunos');
                if (select && escolas && !escolas.erro) {
                    const current = select.value;
                    select.innerHTML = '<option value="">Todas as escolas</option>';
                    escolas.forEach(e => {
                        const opt = document.createElement('option');
                        opt.value = e.id;
                        opt.textContent = e.nome;
                        select.appendChild(opt);
                    });
                    if (current) select.value = current;
                }
            } catch (erro) {
                console.error('Erro ao carregar escolas para filtro:', erro);
            }
        }

        // ============================================
        // FILTRAR ALUNOS POR ESCOLA
        // ============================================
        async function filtrarAlunosPorEscola(escolaId) {
            console.log('🔍 Filtrando alunos por escola:', escolaId);
            
            // Limpar seleção de turma quando mudar a escola
            const selectTurma = document.getElementById('filtro-turma-alunos');
            if (selectTurma) {
                selectTurma.innerHTML = '<option value="">Todas as turmas</option>';
                if (escolaId && escolaId !== '') {
                    try {
                        const response = await fetch(`${API_URL}/api/turmas?escola_id=${escolaId}`);
                        const turmas = await response.json();
                        if (turmas && !turmas.erro) {
                            turmas.forEach(t => {
                                const opt = document.createElement('option');
                                opt.value = t.id;
                                opt.textContent = t.nome + ' - ' + (t.serie || '');
                                selectTurma.appendChild(opt);
                            });
                        }
                    } catch (e) {
                        console.error('Erro ao carregar turmas:', e);
                    }
                }
            }
            
            // Recarregar alunos com o filtro de escola
            await carregarAlunos(escolaId);
        }

        // ============================================
        // FILTRAR ALUNOS POR SÉRIE
        // ============================================
        async function filtrarAlunosPorSerie(serie) {
            console.log('🔍 Filtrando alunos por série:', serie);
            const escolaId = document.getElementById('filtro-escola-alunos')?.value || '';
            await carregarAlunos(escolaId);
        }

        // ============================================
        // CARREGAR ALUNOS COM FILTRO
        // ============================================
        async function carregarAlunos(escolaId = null) {
            try {
                let url = API_URL + '/api/alunos';
                const params = new URLSearchParams();
                
                // Adicionar filtro de escola se fornecido
                if (escolaId && escolaId !== '' && escolaId !== 'null' && escolaId !== 'undefined') {
                    params.append('escola_id', escolaId);
                }
                
                // Adicionar filtro de turma se existir
                const selectTurma = document.getElementById('filtro-turma-alunos');
                if (selectTurma && selectTurma.value && selectTurma.value !== '') {
                    params.append('turma_id', selectTurma.value);
                }
                
                // Adicionar filtro de série
                const selectSerie = document.getElementById('filtro-serie-alunos');
                if (selectSerie && selectSerie.value && selectSerie.value !== '') {
                    params.append('serie', selectSerie.value);
                }
                
                const queryString = params.toString();
                if (queryString) {
                    url += '?' + queryString;
                }
                
                console.log('📤 URL da requisição:', url);
                
                const response = await fetch(url);
                const alunos = await response.json();
                const tbody = document.getElementById('tb-alunos');
                if (!tbody) return;

                if (!alunos || alunos.length === 0 || alunos.erro) {
                    tbody.innerHTML = '<tr><td colspan="8" style="text-align:center;padding:30px;color:var(--text3);">Nenhum aluno cadastrado com os filtros selecionados</td></tr>';
                } else {
                    const corMap = {
                        '1º Ano': 'badge-purple', '2º Ano': 'badge-purple', '3º Ano': 'badge-blue',
                        '4º Ano': 'badge-blue', '5º Ano': 'badge-blue', '6º Ano': 'badge-cyan',
                        '7º Ano': 'badge-cyan', '8º Ano': 'badge-orange', '9º Ano': 'badge-orange'
                    };
                    tbody.innerHTML = alunos.map((a, i) => {
                        return '<tr data-id="' + a.id + '" data-nome="' + a.nome + '">' +
                            '<td><span class="badge badge-blue">' + String(a.numero_chamada || i + 1).padStart(2, '0') + '</span></td>' +
                            '<td><span class="chip">' + (a.matricula || '—') + '</span></td>' +
                            '<td><strong>' + a.nome + '</strong></td>' +
                            '<td><span class="badge ' + (corMap[a.turma_serie] || 'badge-blue') + '">' + (a.turma_serie || '—') + '</span></td>' +
                            '<td>' + (a.turma_nome || '—') + '</td>' +
                            '<td><span class="badge badge-gray">' + (a.escola_nome || '—') + '</span></td>' +
                            '<td>' + (a.data_nascimento ? new Date(a.data_nascimento).toLocaleDateString() : '—') + '</td>' +
                            '<td><div class="btn-group"><button class="btn btn-outline btn-sm" onclick="editarAluno(' + a.id + ')">✏️</button><button class="btn-del" onclick="excluirAluno(' + a.id + ', \'' + a.nome + '\')">🗑️</button></div></td></tr>';
                    }).join('');
                }
            } catch (erro) {
                console.error('Erro ao carregar alunos:', erro);
                const tbody = document.getElementById('tb-alunos');
                if (tbody) {
                    tbody.innerHTML = '<tr><td colspan="8" style="text-align:center;padding:30px;color:var(--text3);">Erro ao carregar alunos</td></tr>';
                }
            }
        }

        // ============================================
        // CARREGAR DADOS - CHAMADA INICIAL
        // ============================================
        async function carregarDados() {
            console.log('🔄 Carregando dados do sistema...');
            try {
                await Promise.all([
                    carregarEscolas(),
                    carregarTurmas(),
                    carregarAlunos(),
                    carregarProvas(),
                    carregarDashboard(),
                    carregarResultados(),
                    carregarGabaritos(),
                    carregarCombos(),
                    carregarRelatorios(),
                    carregarUltimasCorrecoes(),
                    carregarUserData(),
                    carregarDesempenhoReal(),
                    carregarUsuarios(),
                    carregarEscolasFiltroAlunos()
                ]);
                console.log('✅ Todos os dados carregados com sucesso!');
            } catch (erro) {
                console.error('❌ Erro ao carregar dados:', erro);
                showToast('⚠️ Erro ao carregar alguns dados. Verifique a conexão com o servidor.', 'error');
            }
        }

        // ============================================
        // FUNÇÕES DE EDIÇÃO (ESCOLA, TURMA, ALUNO)
        // ============================================
        function editarEscola(id) {
            showToast('✏️ Carregando dados da escola...', 'info');
            fetch(`${API_URL}/api/escolas/${id}`)
                .then(r => r.json())
                .then(escola => {
                    if (escola.erro || !escola) {
                        showToast('❌ Escola não encontrada!', 'error');
                        return;
                    }
                    document.getElementById('editar-escola-id').value = id;
                    document.getElementById('editar-escola-nome').value = escola.nome || '';
                    document.getElementById('editar-escola-inep').value = escola.inep || '';
                    document.getElementById('editar-escola-municipio').value = escola.municipio || '';
                    document.getElementById('editar-escola-estado').value = escola.estado || 'PA';
                    document.getElementById('editar-escola-telefone').value = escola.telefone || '';
                    document.getElementById('editar-escola-diretor').value = escola.diretor || '';
                    openM('m-editar-escola');
                    showToast('✏️ Editando escola: ' + escola.nome, 'info');
                })
                .catch(erro => {
                    console.error('Erro ao carregar escola:', erro);
                    showToast('❌ Erro ao carregar dados da escola', 'error');
                });
        }

        async function salvarEdicaoEscola() {
            const id = document.getElementById('editar-escola-id').value;
            const dados = {
                nome: document.getElementById('editar-escola-nome').value.trim(),
                inep: document.getElementById('editar-escola-inep').value.trim() || '',
                municipio: document.getElementById('editar-escola-municipio').value.trim() || '',
                estado: document.getElementById('editar-escola-estado').value || 'PA',
                telefone: document.getElementById('editar-escola-telefone').value.trim() || '',
                diretor: document.getElementById('editar-escola-diretor').value.trim() || ''
            };
            if (!dados.nome) {
                showToast('❌ Nome da escola é obrigatório!', 'error');
                return;
            }
            try {
                const response = await fetch(`${API_URL}/api/escolas/${id}`, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(dados)
                });
                const result = await response.json();
                if (response.ok) {
                    showToast('✅ Escola atualizada com sucesso!', 'success');
                    closeM('m-editar-escola');
                    carregarEscolas();
                    carregarEscolasFiltroAlunos();
                } else {
                    showToast('❌ Erro: ' + (result.erro || 'Erro desconhecido'), 'error');
                }
            } catch (erro) {
                console.error('Erro ao editar escola:', erro);
                showToast('❌ Erro ao salvar alterações', 'error');
            }
        }

        function editarTurma(id) {
            showToast('✏️ Carregando dados da turma...', 'info');
            fetch(`${API_URL}/api/escolas`)
                .then(r => r.json())
                .then(escolas => {
                    const select = document.getElementById('editar-turma-escola');
                    select.innerHTML = '<option value="">Selecione a escola</option>';
                    if (escolas && !escolas.erro) {
                        escolas.forEach(e => {
                            const opt = document.createElement('option');
                            opt.value = e.id;
                            opt.textContent = e.nome;
                            select.appendChild(opt);
                        });
                    }
                })
                .catch(e => console.error('Erro ao carregar escolas:', e));

            fetch(`${API_URL}/api/turmas/${id}`)
                .then(r => r.json())
                .then(turma => {
                    if (turma.erro || !turma) {
                        showToast('❌ Turma não encontrada!', 'error');
                        return;
                    }
                    document.getElementById('editar-turma-id').value = id;
                    document.getElementById('editar-turma-escola').value = turma.escola_id || '';
                    document.getElementById('editar-turma-nome').value = turma.nome || '';
                    document.getElementById('editar-turma-serie').value = turma.serie || '1º Ano';
                    document.getElementById('editar-turma-turno').value = turma.turno || 'Manhã';
                    document.getElementById('editar-turma-professor').value = turma.professor || '';
                    document.getElementById('editar-turma-capacidade').value = turma.capacidade || 35;
                    document.getElementById('editar-turma-ano').value = turma.ano_letivo || 2025;
                    openM('m-editar-turma');
                    showToast('✏️ Editando turma: ' + turma.nome, 'info');
                })
                .catch(erro => {
                    console.error('Erro ao carregar turma:', erro);
                    showToast('❌ Erro ao carregar dados da turma', 'error');
                });
        }

        async function salvarEdicaoTurma() {
            const id = document.getElementById('editar-turma-id').value;
            const dados = {
                escola_id: parseInt(document.getElementById('editar-turma-escola').value) || null,
                nome: document.getElementById('editar-turma-nome').value.trim(),
                serie: document.getElementById('editar-turma-serie').value || '1º Ano',
                turno: document.getElementById('editar-turma-turno').value || 'Manhã',
                professor: document.getElementById('editar-turma-professor').value.trim() || '',
                capacidade: parseInt(document.getElementById('editar-turma-capacidade').value) || 35,
                ano_letivo: parseInt(document.getElementById('editar-turma-ano').value) || 2025
            };
            if (!dados.escola_id) {
                showToast('❌ Selecione uma escola!', 'error');
                return;
            }
            if (!dados.nome) {
                showToast('❌ Nome da turma é obrigatório!', 'error');
                return;
            }
            try {
                const response = await fetch(`${API_URL}/api/turmas/${id}`, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(dados)
                });
                const result = await response.json();
                if (response.ok) {
                    showToast('✅ Turma atualizada com sucesso!', 'success');
                    closeM('m-editar-turma');
                    carregarTurmas();
                } else {
                    showToast('❌ Erro: ' + (result.erro || 'Erro desconhecido'), 'error');
                }
            } catch (erro) {
                console.error('Erro ao editar turma:', erro);
                showToast('❌ Erro ao salvar alterações', 'error');
            }
        }

        function editarAluno(id) {
            showToast('✏️ Carregando dados do aluno...', 'info');
            fetch(`${API_URL}/api/turmas`)
                .then(r => r.json())
                .then(turmas => {
                    const select = document.getElementById('editar-aluno-turma');
                    select.innerHTML = '<option value="">Selecione a turma</option>';
                    if (turmas && !turmas.erro) {
                        turmas.forEach(t => {
                            const opt = document.createElement('option');
                            opt.value = t.id;
                            opt.textContent = t.nome + ' - ' + (t.serie || '');
                            select.appendChild(opt);
                        });
                    }
                })
                .catch(e => console.error('Erro ao carregar turmas:', e));

            fetch(`${API_URL}/api/alunos/${id}`)
                .then(r => r.json())
                .then(aluno => {
                    if (aluno.erro || !aluno) {
                        showToast('❌ Aluno não encontrado!', 'error');
                        return;
                    }
                    document.getElementById('editar-aluno-id').value = id;
                    document.getElementById('editar-aluno-numero').value = aluno.numero_chamada || '';
                    document.getElementById('editar-aluno-matricula').value = aluno.matricula || '';
                    document.getElementById('editar-aluno-nome').value = aluno.nome || '';
                    document.getElementById('editar-aluno-nascimento').value = aluno.data_nascimento || '';
                    document.getElementById('editar-aluno-genero').value = aluno.genero || 'Masculino';
                    document.getElementById('editar-aluno-turma').value = aluno.turma_id || '';
                    document.getElementById('editar-aluno-responsavel').value = aluno.responsavel || '';
                    document.getElementById('editar-aluno-telefone').value = aluno.telefone || '';
                    document.getElementById('editar-aluno-email').value = aluno.email || '';
                    document.getElementById('editar-aluno-observacoes').value = aluno.observacoes || '';
                    openM('m-editar-aluno');
                    showToast('✏️ Editando aluno: ' + aluno.nome, 'info');
                })
                .catch(erro => {
                    console.error('Erro ao carregar aluno:', erro);
                    showToast('❌ Erro ao carregar dados do aluno', 'error');
                });
        }

        async function salvarEdicaoAluno() {
            const id = document.getElementById('editar-aluno-id').value;
            const dados = {
                turma_id: parseInt(document.getElementById('editar-aluno-turma').value) || null,
                nome: document.getElementById('editar-aluno-nome').value.trim(),
                matricula: document.getElementById('editar-aluno-matricula').value.trim() || '',
                numero_chamada: parseInt(document.getElementById('editar-aluno-numero').value) || null,
                data_nascimento: document.getElementById('editar-aluno-nascimento').value || null,
                genero: document.getElementById('editar-aluno-genero').value || 'Masculino',
                responsavel: document.getElementById('editar-aluno-responsavel').value.trim() || '',
                telefone: document.getElementById('editar-aluno-telefone').value.trim() || '',
                email: document.getElementById('editar-aluno-email').value.trim() || '',
                observacoes: document.getElementById('editar-aluno-observacoes').value.trim() || ''
            };
            if (!dados.nome) {
                showToast('❌ Nome do aluno é obrigatório!', 'error');
                return;
            }
            if (!dados.turma_id) {
                showToast('❌ Selecione a turma do aluno!', 'error');
                return;
            }
            try {
                const response = await fetch(`${API_URL}/api/alunos/${id}`, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(dados)
                });
                const result = await response.json();
                if (response.ok) {
                    showToast('✅ Aluno atualizado com sucesso!', 'success');
                    closeM('m-editar-aluno');
                    carregarAlunos();
                } else {
                    showToast('❌ Erro: ' + (result.erro || 'Erro desconhecido'), 'error');
                }
            } catch (erro) {
                console.error('Erro ao editar aluno:', erro);
                showToast('❌ Erro ao salvar alterações', 'error');
            }
        }

        // ============================================
        // EXCLUIR FUNCTIONS
        // ============================================
        async function excluirEscola(id, nome) {
            if (!confirm('Excluir a escola "' + nome + '"? Isso também excluirá todas as turmas e alunos vinculados.')) return;
            try {
                const response = await fetch(API_URL + '/api/escolas/' + id, { method: 'DELETE' });
                if (response.ok) {
                    showToast('🗑️ Escola "' + nome + '" excluída!', 'error');
                    carregarDados();
                    carregarEscolasFiltroAlunos();
                } else {
                    const erro = await response.json();
                    showToast('Erro: ' + (erro.erro || 'Erro desconhecido'), 'error');
                }
            } catch (erro) {
                showToast('Erro ao excluir: ' + erro.message, 'error');
            }
        }

        async function excluirTurma(id, nome) {
            if (!confirm('Excluir a turma "' + nome + '"? Isso também excluirá todos os alunos vinculados.')) return;
            try {
                const response = await fetch(API_URL + '/api/turmas/' + id, { method: 'DELETE' });
                if (response.ok) {
                    showToast('🗑️ Turma "' + nome + '" excluída!', 'error');
                    carregarDados();
                } else {
                    const erro = await response.json();
                    showToast('Erro: ' + (erro.erro || 'Erro desconhecido'), 'error');
                }
            } catch (erro) {
                showToast('Erro ao excluir: ' + erro.message, 'error');
            }
        }

        async function excluirAluno(id, nome) {
            if (!confirm('Excluir o aluno "' + nome + '"?')) return;
            try {
                const response = await fetch(API_URL + '/api/alunos/' + id, { method: 'DELETE' });
                if (response.ok) {
                    showToast('🗑️ Aluno "' + nome + '" excluído!', 'error');
                    carregarDados();
                } else {
                    const erro = await response.json();
                    showToast('Erro: ' + (erro.erro || 'Erro desconhecido'), 'error');
                }
            } catch (erro) {
                showToast('Erro ao excluir: ' + erro.message, 'error');
            }
        }

        // ============================================
        // CARREGAR ESCOLAS
        // ============================================
        async function carregarEscolas() {
            try {
                const response = await fetch(`${API_URL}/api/escolas`);
                const escolas = await response.json();
                const tbody = document.getElementById('tb-escola');
                if (!tbody) return;

                if (!escolas || escolas.length === 0 || escolas.erro) {
                    tbody.innerHTML = '<tr><td colspan="8" style="text-align:center;padding:30px;color:var(--text3);">Nenhuma escola cadastrada</td></tr>';
                } else {
                    const turmasResp = await fetch(`${API_URL}/api/turmas`);
                    const turmas = await turmasResp.json();
                    const alunosResp = await fetch(`${API_URL}/api/alunos`);
                    const alunos = await alunosResp.json();

                    tbody.innerHTML = escolas.map((e, i) => {
                        const turmasCount = turmas.filter(t => t.escola_id === e.id).length;
                        const alunosCount = alunos.filter(a => a.escola_id === e.id).length;
                        return '<tr data-id="' + e.id + '" data-nome="' + e.nome + '">' +
                            '<td><span class="badge badge-blue">' + String(i + 1).padStart(3, '0') + '</span></td>' +
                            '<td><strong>' + e.nome + '</strong></td>' +
                            '<td>' + (e.municipio || '—') + (e.estado ? ' — ' + e.estado : '') + '</td>' +
                            '<td><span class="chip">' + (e.inep || '—') + '</span></td>' +
                            '<td>' + (e.diretor || '—') + '</td>' +
                            '<td>' + turmasCount + '</td>' +
                            '<td>' + alunosCount + '</td>' +
                            '<td><div class="btn-group"><button class="btn btn-outline btn-sm" onclick="editarEscola(' + e.id + ')">✏️ Editar</button><button class="btn-del" onclick="excluirEscola(' + e.id + ', \'' + e.nome + '\')" title="Excluir">🗑️</button></div></td></tr>';
                    }).join('');
                }
            } catch (erro) {
                console.error('Erro ao carregar escolas:', erro);
            }
        }

        // ============================================
        // CARREGAR TURMAS
        // ============================================
        async function carregarTurmas() {
            try {
                const response = await fetch(API_URL + '/api/turmas');
                const turmas = await response.json();
                const tbody = document.getElementById('tb-turmas');
                if (!tbody) return;

                if (!turmas || turmas.length === 0 || turmas.erro) {
                    tbody.innerHTML = '<tr><td colspan="8" style="text-align:center;padding:30px;color:var(--text3);">Nenhuma turma cadastrada</td></tr>';
                } else {
                    const corMap = { '1º Ano': 'badge-purple', '2º Ano': 'badge-purple', '3º Ano': 'badge-blue',
                        '4º Ano': 'badge-blue', '5º Ano': 'badge-blue', '6º Ano': 'badge-cyan',
                        '7º Ano': 'badge-cyan', '8º Ano': 'badge-orange', '9º Ano': 'badge-orange' };
                    
                    tbody.innerHTML = turmas.map((t, i) => {
                        const totalAlunos = t.total_alunos || 0;
                        return '<tr data-id="' + t.id + '" data-nome="' + t.nome + '" data-serie="' + (t.serie || '') + '">' +
                            '<td><span class="badge badge-gray">' + String(i + 1).padStart(2, '0') + '</span></td>' +
                            '<td><strong>' + t.nome + '</strong></td>' +
                            '<td><span class="badge ' + (corMap[t.serie] || 'badge-blue') + '">' + (t.serie || '—') + '</span></td>' +
                            '<td>' + (t.turno || 'Manhã') + '</td>' +
                            '<td>' + (t.escola_nome || '—') + '</td>' +
                            '<td>' + (t.professor || '—') + '</td>' +
                            '<td><span class="badge badge-blue">' + totalAlunos + '</span></td>' +
                            '<td><div class="btn-group">' +
                            '<button class="btn btn-outline btn-sm" onclick="editarTurma(' + t.id + ')">✏️</button>' +
                            '<button class="btn btn-green btn-sm" onclick="verAlunosDaTurma(' + t.id + ')" title="Lista de Alunos">📋</button>' +
                            '<button class="btn-del" onclick="excluirTurma(' + t.id + ', \'' + t.nome + '\')">🗑️</button>' +
                            '</div></td></tr>';
                    }).join('');
                }
            } catch (erro) {
                console.error('Erro ao carregar turmas:', erro);
                const tbody = document.getElementById('tb-turmas');
                if (tbody) {
                    tbody.innerHTML = '<tr><td colspan="8" style="text-align:center;padding:30px;color:var(--text3);">Erro ao carregar turmas</td></tr>';
                }
            }
        }

        // ============================================
        // CARREGAR PROVAS
        // ============================================
        async function carregarProvas() {
            try {
                const response = await fetch(API_URL + '/api/provas');
                const provas = await response.json();
                const tbody = document.getElementById('tb-provas');
                if (!tbody) return;

                if (!provas || provas.length === 0 || provas.erro) {
                    tbody.innerHTML = '<tr><td colspan="7" style="text-align:center;padding:30px;color:var(--text3);">Nenhuma prova cadastrada</td></tr>';
                } else {
                    tbody.innerHTML = provas.map((p, i) => {
                        return '<tr data-id="' + p.id + '" data-nome="' + p.titulo + '">' +
                            '<td><span class="badge badge-blue">' + String(i + 1).padStart(3, '0') + '</span></td>' +
                            '<td><strong>' + p.titulo + '</strong></td>' +
                            '<td><span class="badge badge-purple">' + (p.turma_serie || '—') + '</span></td>' +
                            '<td>' + (p.turma_nome || '—') + '</td>' +
                            '<td>' + (p.data_prova || '—') + '</td>' +
                            '<td><span class="badge ' + (p.gabarito && p.gabarito.length > 0 ? 'badge-green' : 'badge-orange') + '">' + (p.gabarito && p.gabarito.length > 0 ? 'Com Gabarito' : 'Sem Gabarito') + '</span></td>' +
                            '<td><div class="btn-group"><button class="btn btn-outline btn-sm" onclick="editarProva(' + p.id + ')">👁️</button>' + (p.gabarito && p.gabarito.length > 0 ? '' : '<button class="btn btn-primary btn-sm" onclick="go(\'gabarito\')">+ Gabarito</button>') + '<button class="btn-del" onclick="excluirProva(' + p.id + ', \'' + p.titulo + '\')">🗑️</button></div></td></tr>';
                    }).join('');
                }
            } catch (erro) {
                console.error('Erro ao carregar provas:', erro);
            }
        }

        async function excluirProva(id, titulo) {
            if (!confirm('Excluir a prova "' + titulo + '"?')) return;
            try {
                const response = await fetch(API_URL + '/api/provas/' + id, { method: 'DELETE' });
                if (response.ok) {
                    showToast('🗑️ Prova "' + titulo + '" excluída!', 'error');
                    carregarDados();
                } else {
                    const erro = await response.json();
                    showToast('Erro: ' + (erro.erro || 'Erro desconhecido'), 'error');
                }
            } catch (erro) {
                showToast('Erro ao excluir: ' + erro.message, 'error');
            }
        }

        function editarProva(id) {
            fetch(API_URL + '/api/provas/' + id).then(r => r.json()).then(prova => {
                if (prova.erro || !prova) { showToast('❌ Prova não encontrada!', 'error'); return; }
                const is1Ano = prova.turma_serie && prova.turma_serie.startsWith('1');
                const gabarito = prova.gabarito || [];
                const container = document.createElement('div');
                container.style.cssText = 'position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.85);backdrop-filter:blur(10px);z-index:9999;display:flex;align-items:center;justify-content:center;padding:20px;overflow-y:auto;';
                let html = '<div style="background:var(--surface);border:1px solid var(--border2);border-radius:16px;padding:32px;max-width:800px;width:100%;max-height:90vh;overflow-y:auto;position:relative;box-shadow:0 32px 80px rgba(0,0,0,0.6);">';
                html += '<button onclick="this.closest(\'div[style]\').remove()" style="position:sticky;top:0;float:right;background:rgba(239,68,68,0.2);border:1px solid rgba(239,68,68,0.4);color:#fc8181;width:36px;height:36px;border-radius:50%;font-size:20px;cursor:pointer;z-index:10;display:flex;align-items:center;justify-content:center;margin-bottom:10px;">✕</button>';
                html += '<div style="border-bottom:1px solid var(--border);padding-bottom:16px;margin-bottom:20px;"><h2 style="font-size:22px;font-weight:800;color:var(--text);">📄 ' + (prova.titulo || 'Prova') + '</h2><div style="display:flex;flex-wrap:wrap;gap:12px;margin-top:10px;font-size:13px;color:var(--text2);"><span>🏷️ Disciplina: <strong style="color:var(--text);">' + (prova.disciplina || '—') + '</strong></span><span>📚 Série: <strong style="color:var(--text);">' + (prova.turma_serie || '—') + '</strong></span><span>👥 Turma: <strong style="color:var(--text);">' + (prova.turma_nome || '—') + '</strong></span><span>📅 Data: <strong style="color:var(--text);">' + (prova.data_prova || '—') + '</strong></span><span>📊 Questões: <strong style="color:var(--text);">' + (gabarito.length || 0) + '</strong></span><span style="background:' + (is1Ano ? 'rgba(139,92,246,0.15)' : 'rgba(59,130,246,0.15)') + ';padding:2px 10px;border-radius:20px;border:1px solid ' + (is1Ano ? 'rgba(139,92,246,0.3)' : 'rgba(59,130,246,0.3)') + ';">' + (is1Ano ? '🔵 3 alternativas (A,B,C)' : '🟦 4 alternativas (A,B,C,D)') + '</span></div></div>';
                html += '<div style="margin-bottom:20px;"><h3 style="font-size:14px;font-weight:700;color:var(--text2);margin-bottom:12px;text-transform:uppercase;letter-spacing:0.5px;">✅ Gabarito da Prova</h3><div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(60px,1fr));gap:6px;max-height:300px;overflow-y:auto;padding:4px;">' + (gabarito.map((resp, i) => '<div style="background:var(--bg2);border:1px solid var(--border2);border-radius:8px;padding:8px 4px;text-align:center;"><div style="font-size:9px;color:var(--text3);font-weight:700;margin-bottom:2px;">Q' + (i + 1) + '</div><div style="font-size:16px;font-weight:800;color:var(--green);background:rgba(16,185,129,0.1);border-radius:6px;padding:4px 0;">' + (resp || '—') + '</div></div>').join('') || '<div style="grid-column:1/-1;text-align:center;color:var(--text3);padding:20px;">⚠️ Nenhum gabarito cadastrado</div>') + '</div></div>';
                html += '<div style="display:flex;gap:10px;flex-wrap:wrap;padding-top:16px;border-top:1px solid var(--border);"><button onclick="go(\'corrigir-ia\')" class="btn btn-purple" style="flex:1;justify-content:center;">🤖 Corrigir com IA</button><button onclick="this.closest(\'div[style]\').remove()" class="btn btn-outline" style="flex:1;justify-content:center;">✕ Fechar</button><button onclick="window.print()" class="btn btn-outline">🖨️ Imprimir</button></div></div>';
                container.innerHTML = html;
                document.body.appendChild(container);
                container.addEventListener('click', function(e) { if (e.target === this) this.remove(); });
                showToast('👁️ Visualizando prova: ' + prova.titulo, 'info');
            }).catch(erro => { console.error('Erro ao carregar prova:', erro); showToast('❌ Erro ao visualizar prova', 'error'); });
        }

        // ============================================
        // CARREGAR GABARITOS
        // ============================================
        async function carregarGabaritos() {
            try {
                const response = await fetch(API_URL + '/api/provas');
                const provas = await response.json();
                const tbody = document.getElementById('tb-gabaritos');
                if (!tbody) return;
                const comGabarito = provas.filter(p => p.gabarito && p.gabarito.length > 0);
                if (!comGabarito || comGabarito.length === 0) {
                    tbody.innerHTML = '<tr><td colspan="7" style="text-align:center;padding:30px;color:var(--text3);">Nenhum gabarito cadastrado</td></tr>';
                } else {
                    tbody.innerHTML = comGabarito.map((p, i) => {
                        return '<tr data-id="' + p.id + '" data-nome="' + p.titulo + '">' +
                            '<td><span class="badge badge-blue">' + String(i + 1).padStart(3, '0') + '</span></td>' +
                            '<td>' + p.titulo + '</td>' +
                            '<td><span class="badge badge-purple">' + (p.turma_serie || '—') + '</span></td>' +
                            '<td>' + (p.quantidade_questoes || p.gabarito?.length || 0) + '</td>' +
                            '<td><span class="badge ' + (p.tipo_questoes == '3' ? 'badge-purple' : 'badge-blue') + '">' + (p.tipo_questoes == '3' ? 'A, B, C' : 'A, B, C, D') + '</span></td>' +
                            '<td>' + (p.data_prova || '—') + '</td>' +
                            '<td><div class="btn-group"><button class="btn btn-outline btn-sm" onclick="editarGabarito(' + p.id + ')">✏️</button><button class="btn-del" onclick="excluirGabarito(' + p.id + ', \'' + p.titulo + '\')">🗑️</button></div></td></tr>';
                    }).join('');
                }
            } catch (erro) { console.error('Erro ao carregar gabaritos:', erro); }
        }

        function editarGabarito(id) { showToast('✏️ Editando gabarito da prova ID ' + id + '...', 'info'); go('gabarito'); }
        async function excluirGabarito(id, titulo) {
            if (!confirm('Excluir o gabarito da prova "' + titulo + '"?')) return;
            try {
                const response = await fetch(API_URL + '/api/provas/' + id, { method: 'DELETE' });
                if (response.ok) { showToast('🗑️ Gabarito da prova "' + titulo + '" excluído!', 'error'); carregarDados(); } else { const erro = await response.json(); showToast('Erro: ' + (erro.erro || 'Erro desconhecido'), 'error'); }
            } catch (erro) { showToast('Erro ao excluir: ' + erro.message, 'error'); }
        }

        // ============================================
        // CARREGAR RESULTADOS
        // ============================================
        async function carregarResultados() {
            try {
                const response = await fetch(`${API_URL}/api/historico`);
                const historico = await response.json();
                const tbody = document.getElementById('tb-resultados');
                if (!tbody) return;

                if (!historico || historico.length === 0 || historico.erro) {
                    tbody.innerHTML = '<tr><td colspan="9" style="text-align:center;padding:30px;color:var(--text3);">Nenhuma correção encontrada</td></tr>';
                    return;
                }

                historico.sort((a, b) => b.nota - a.nota);

                tbody.innerHTML = historico.map((item, index) => {
                    const medalha = index === 0 ? '🥇' : index === 1 ? '🥈' : index === 2 ? '🥉' : (index + 1);
                    const nota = item.nota || 0;
                    const totalQuestoes = 20;
                    const acertos = item.acertos || 0;
                    const porcentagem = totalQuestoes > 0 ? Math.round((acertos / totalQuestoes) * 100) : 0;
                    const conceito = calcularConceito(porcentagem);
                    const status = nota >= 5 ? 'Aprovado' : (nota >= 3 ? 'Recomposição da Aprendizagem' : 'Reprovado');
                    const badge = nota >= 5 ? 'badge-green' : (nota >= 3 ? 'badge-orange' : 'badge-red');
                    const cor = nota >= 5 ? 'var(--green)' : (nota >= 3 ? 'var(--orange)' : 'var(--red)');
                    const badgeConceito = `badge-conceito-${conceito.toLowerCase().replace(' ', '-')}`;

                    return '<tr>' +
                        '<td>' + medalha + '</td>' +
                        '<td>' + (index + 1) + '</td>' +
                        '<td><strong>' + (item.aluno_nome || 'Aluno') + '</strong></td>' +
                        '<td><span class="badge badge-purple">' + (item.serie || '—') + '</span></td>' +
                        '<td>' + acertos + '</td>' +
                        '<td><strong>' + porcentagem + '%</strong></td>' +
                        '<td><span class="badge ' + badgeConceito + '">' + conceito + '</span></td>' +
                        '<td><strong style="color:' + cor + ';">' + nota.toFixed(1) + '</strong></td>' +
                        '<td><span class="badge ' + badge + '">' + status + '</span></td>' +
                        '</tr>';
                }).join('');

            } catch (erro) {
                console.error('Erro ao carregar resultados:', erro);
                const tbody = document.getElementById('tb-resultados');
                if (tbody) {
                    tbody.innerHTML = '<tr><td colspan="9" style="text-align:center;padding:30px;color:var(--text3);">Erro ao carregar resultados</td></tr>';
                }
            }
        }

        // ============================================
        // CARREGAR DASHBOARD
        // ============================================
        async function carregarDashboard() {
            try {
                const response = await fetch(API_URL + '/api/dashboard');
                const dados = await response.json();
                document.getElementById('totalEscolas').textContent = dados.total_escolas || 0;
                document.getElementById('totalTurmas').textContent = dados.total_turmas || 0;
                document.getElementById('totalAlunos').textContent = dados.total_alunos || 0;
                document.getElementById('totalProvas').textContent = dados.total_provas || 0;
                document.getElementById('u-total-escolas').textContent = dados.total_escolas || 0;
                document.getElementById('u-total-turmas').textContent = dados.total_turmas || 0;
                document.getElementById('u-total-alunos').textContent = dados.total_alunos || 0;
            } catch (erro) { console.error('Erro ao carregar dashboard:', erro); }
        }

        // ============================================
        // CARREGAR ÚLTIMAS CORREÇÕES
        // ============================================
        async function carregarUltimasCorrecoes() {
            try {
                const response = await fetch(API_URL + '/api/historico');
                const historico = await response.json();
                const tbody = document.getElementById('ultimas-correcoes');
                if (!tbody) return;
                if (!historico || historico.length === 0 || historico.erro) {
                    tbody.innerHTML = '<tr><td colspan="4" style="text-align:center;padding:20px;color:var(--text3);">Nenhuma correção recente</td></tr>';
                } else {
                    const recentes = historico.slice(0, 4);
                    tbody.innerHTML = recentes.map(item => {
                        const status = item.nota >= 6 ? 'Aprovado' : 'Reprovado';
                        const cor = item.nota >= 6 ? 'var(--green)' : 'var(--red)';
                        const badge = item.nota >= 6 ? 'badge-green' : 'badge-red';
                        return '<tr><td><strong>' + item.aluno_nome + '</strong></td><td>' + item.prova_titulo + '</td><td><strong style="color:' + cor + ';">' + item.nota + '</strong></td><td><span class="badge ' + badge + '">' + status + '</span></td></tr>';
                    }).join('');
                }
            } catch (erro) { console.error('Erro ao carregar últimas correções:', erro); }
        }

        // ============================================
        // CARREGAR DESEMPENHO REAL
        // ============================================
        async function carregarDesempenhoReal() {
            try {
                const response = await fetch(`${API_URL}/api/dashboard/desempenho`);
                const dados = await response.json();
                const container = document.getElementById('grafico-desempenho');
                const badge = document.getElementById('total-turmas-badge');
                if (!container) return;

                if (dados.erro || !dados || dados.length === 0) {
                    container.innerHTML = `<div style="text-align:center;color:var(--text3);padding:20px;"><div style="font-size:30px;margin-bottom:10px;">📭</div><p>Nenhuma turma com correções ainda.</p><p style="font-size:12px;">Cadastre turmas e faça correções para ver o desempenho.</p></div>`;
                    if (badge) badge.textContent = '0 turmas';
                    return;
                }

                if (badge) badge.textContent = dados.length + ' turmas';

                let html = '<div class="chart-bars">';
                dados.sort((a, b) => b.porcentagem - a.porcentagem);
                const cores = ['linear-gradient(180deg,#3b82f6,#1d4ed8)', 'linear-gradient(180deg,#06b6d4,#0e7490)', 'linear-gradient(180deg,#8b5cf6,#6d28d9)', 'linear-gradient(180deg,#10b981,#047857)', 'linear-gradient(180deg,#f59e0b,#b45309)', 'linear-gradient(180deg,#ec4899,#be185d)'];

                dados.forEach((turma, index) => {
                    const altura = Math.max(20, (turma.porcentagem / 100) * 130);
                    const cor = cores[index % cores.length];
                    html += `<div class="chart-bar-item" title="${turma.nome} - Média: ${turma.media}"><div class="chart-bar-val">${turma.porcentagem}%</div><div class="chart-bar" style="height:${altura}px;background:${cor};"></div><div class="chart-bar-lbl">${turma.nome}</div><div style="font-size:8px;color:var(--text3);margin-top:2px;">${turma.total_correcoes} corr.</div></div>`;
                });
                html += '</div>';
                container.innerHTML = html;

            } catch (erro) {
                console.error('Erro ao carregar desempenho:', erro);
                const container = document.getElementById('grafico-desempenho');
                if (container) {
                    container.innerHTML = `<div style="text-align:center;color:var(--red);padding:20px;"><div style="font-size:30px;margin-bottom:10px;">⚠️</div><p>Erro ao carregar dados de desempenho.</p></div>`;
                }
            }
        }

        // ============================================
        // CARREGAR RELATÓRIOS
        // ============================================
        async function carregarRelatorios() {
            try {
                const alunosResp = await fetch(API_URL + '/api/alunos');
                const alunos = await alunosResp.json();
                const correcoesResp = await fetch(API_URL + '/api/historico');
                const correcoes = await correcoesResp.json();
                const totalAlunos = alunos.length || 0,
                    Habilidades = correcoes.filter(c => c.nota >= 6).length || 0,
                    recuperacao = correcoes.filter(c => c.nota >= 4 && c.nota < 6).length || 0,
                    media = correcoes.length > 0 ? (correcoes.reduce((s, c) => s + c.nota, 0) / correcoes.length) : 0;
                document.getElementById('rel-total-alunos').textContent = totalAlunos;
                document.getElementById('rel-Habilidades').textContent = Habilidades;
                document.getElementById('rel-recuperacao').textContent = recuperacao;
                document.getElementById('rel-media').textContent = media.toFixed(1);
                const faixas = { '0-2': 0, '2-4': 0, '4-6': 0, '6-8': 0, '8-10': 0 };
                correcoes.forEach(c => { if (c.nota < 2) faixas['0-2']++; else if (c.nota < 4) faixas['2-4']++; else if (c.nota < 6) faixas['4-6']++; else if (c.nota < 8) faixas['6-8']++; else faixas['8-10']++; });
                const maxVal = Math.max(...Object.values(faixas), 1);
                document.getElementById('d0-2').textContent = faixas['0-2'];
                document.getElementById('d2-4').textContent = faixas['2-4'];
                document.getElementById('d4-6').textContent = faixas['4-6'];
                document.getElementById('d6-8').textContent = faixas['6-8'];
                document.getElementById('d8-10').textContent = faixas['8-10'];
                const bars = document.querySelectorAll('#dist-notas .chart-bar');
                const vals = [faixas['0-2'], faixas['2-4'], faixas['4-6'], faixas['6-8'], faixas['8-10']];
                vals.forEach((v, i) => { if (bars[i]) { bars[i].style.height = (maxVal > 0 ? Math.max(10, (v / maxVal) * 110) : 10) + 'px'; } });
                await carregarRelatorioEscola();
            } catch (erro) { console.error('Erro ao carregar relatórios:', erro); }
        }

        async function carregarRelatorioEscola() {
            try {
                const escolasResp = await fetch(API_URL + '/api/escolas');
                const escolas = await escolasResp.json();
                const turmasResp = await fetch(API_URL + '/api/turmas');
                const turmas = await turmasResp.json();
                const alunosResp = await fetch(API_URL + '/api/alunos');
                const alunos = await alunosResp.json();
                const correcoesResp = await fetch(API_URL + '/api/historico');
                const correcoes = await correcoesResp.json();
                const tbody = document.getElementById('tb-rel-escola');
                if (!tbody) return;
                if (!escolas || escolas.length === 0) {
                    tbody.innerHTML = '<tr><td colspan="6" style="text-align:center;padding:30px;color:var(--text3);">Nenhuma escola cadastrada</td></tr>';
                } else {
                    tbody.innerHTML = escolas.map(e => {
                        const turmasEscola = turmas.filter(t => t.escola_id === e.id);
                        const alunosEscola = alunos.filter(a => a.escola_id === e.id);
                        const correcoesEscola = correcoes.filter(c => { const aluno = alunos.find(a => a.id === c.aluno_id); return aluno && aluno.escola_id === e.id; });
                        const media = correcoesEscola.length > 0 ? (correcoesEscola.reduce((s, c) => s + c.nota, 0) / correcoesEscola.length) : 0;
                        const Habilidades = correcoesEscola.filter(c => c.nota >= 6).length;
                        const perc = correcoesEscola.length > 0 ? Math.round((Habilidades / correcoesEscola.length) * 100) : 0;
                        return '<tr><td><strong>' + e.nome + '</strong></td><td>' + turmasEscola.length + '</td><td>' + alunosEscola.length + '</td><td><strong style="color:' + (media >= 6 ? 'var(--green)' : 'var(--orange)') + ';">' + media.toFixed(1) + '</strong></td><td>' + perc + '%</td><td><div class="progress" style="width:140px;"><div class="progress-fill ' + (perc >= 70 ? 'pf-green' : 'pf-orange') + '" style="width:' + perc + '%;"></div></div></td></tr>';
                    }).join('');
                }
            } catch (erro) { console.error('Erro ao carregar relatório por escola:', erro); }
        }

        // ============================================
        // CARREGAR COMBOS
        // ============================================
        async function carregarCombos() {
            try {
                const respEscolas = await fetch(API_URL + '/api/escolas');
                const escolas = await respEscolas.json();
                ['turma-escola', 'prova-escola', 'lista-escola', 'editar-turma-escola'].forEach(id => {
                    const select = document.getElementById(id);
                    if (select) {
                        const current = select.value;
                        select.innerHTML = '<option value="">Selecione a escola</option>';
                        if (escolas && !escolas.erro) { escolas.forEach(e => { const opt = document.createElement('option'); opt.value = e.id; opt.textContent = e.nome; select.appendChild(opt); }); }
                        if (current) select.value = current;
                    }
                });
                const respTurmas = await fetch(API_URL + '/api/turmas');
                const turmas = await respTurmas.json();
                ['aluno-turma', 'modal-prova-turma', 'lista-turma', 'editar-aluno-turma'].forEach(id => {
                    const select = document.getElementById(id);
                    if (select) {
                        const current = select.value;
                        select.innerHTML = '<option value="">Selecione a turma</option>';
                        if (turmas && !turmas.erro) { turmas.forEach(t => { const opt = document.createElement('option'); opt.value = t.id; opt.textContent = t.nome + ' - ' + (t.serie || '—'); select.appendChild(opt); }); }
                        if (current) select.value = current;
                    }
                });
                const respProvas = await fetch(API_URL + '/api/provas');
                const provas = await respProvas.json();
                ['gab-prova', 'corrigir-prova', 'rel-prova-select'].forEach(id => {
                    const select = document.getElementById(id);
                    if (select) {
                        const current = select.value;
                        select.innerHTML = '<option value="">Selecione a prova</option>';
                        if (provas && !provas.erro) { provas.forEach(p => { const opt = document.createElement('option'); opt.value = p.id; const serie = p.turma_serie || 'Série não definida'; opt.textContent = p.titulo + ' - ' + serie; opt.dataset.serie = serie; select.appendChild(opt); }); }
                        if (current) select.value = current;
                    }
                });
                const respAlunos = await fetch(API_URL + '/api/alunos');
                const alunos = await respAlunos.json();
                ['corrigir-aluno', 'txt-aluno-select', 'rel-aluno-select'].forEach(id => {
                    const select = document.getElementById(id);
                    if (select) {
                        const current = select.value;
                        select.innerHTML = '<option value="">Selecione o aluno</option>';
                        if (alunos && !alunos.erro) { alunos.forEach(a => { const opt = document.createElement('option'); opt.value = a.id; opt.textContent = a.nome; select.appendChild(opt); }); }
                        if (current) select.value = current;
                    }
                });
                const selectProva = document.getElementById('corrigir-prova');
                const selectSerie = document.getElementById('corrigir-serie');
                if (selectProva && selectSerie) {
                    selectProva.onchange = function() {
                        const selected = this.options[this.selectedIndex];
                        const serie = selected?.dataset?.serie || '';
                        if (serie) {
                            const options = selectSerie.options;
                            let found = false;
                            for (let i = 0; i < options.length; i++) {
                                if (options[i].text === serie || options[i].value === serie) { selectSerie.value = options[i].value; found = true; break; }
                            }
                            if (!found) { selectSerie.value = serie; }
                        } else selectSerie.value = '';
                    };
                    if (selectProva.value) selectProva.dispatchEvent(new Event('change'));
                }
            } catch (erro) { console.error('Erro ao carregar combos:', erro); }
        }

        // ============================================
        // GABARITO - BUILD GRID
        // ============================================
        function buildGabGrid() {
            const grid = document.getElementById('gab-grid');
            if (!grid) return;
            const serieEl = document.getElementById('gab-serie');
            const totalEl = document.getElementById('gab-total');
            if (!serieEl || !totalEl) return;
            const is1 = (parseInt(serieEl.value) || 1) === 1;
            const total = parseInt(totalEl.value) || 20;
            const alts = is1 ? ['A', 'B', 'C'] : ['A', 'B', 'C', 'D'];
            const lbl = document.getElementById('gab-label');
            if (lbl) { lbl.textContent = is1 ? '🔵 1º Ano — 3 alternativas: A, B, C' : '🟦 2º ao 9º Ano — 4 alternativas: A, B, C, D'; }
            grid.innerHTML = '';
            for (let i = 1; i <= total; i++) {
                const div = document.createElement('div');
                div.className = 'gab-item';
                let opts = '<option value="">—</option>';
                alts.forEach(a => { opts += '<option>' + a + '</option>'; });
                div.innerHTML = '<div class="gab-num">Q' + i + '</div><select class="gab-select" onchange="this.classList.toggle(\'filled\', this.value!=\'\')">' + opts + '</select>';
                grid.appendChild(div);
            }
        }

        function fillGabRand() {
            const is1 = (parseInt(document.getElementById('gab-serie').value) || 1) === 1;
            const alts = is1 ? ['A', 'B', 'C'] : ['A', 'B', 'C', 'D'];
            document.querySelectorAll('.gab-select').forEach(s => { s.value = alts[Math.floor(Math.random() * alts.length)]; s.classList.add('filled'); });
            showToast('🎲 Gabarito de teste preenchido!');
        }

        function clearGab() { document.querySelectorAll('.gab-select').forEach(s => { s.value = ''; s.classList.remove('filled'); }); }

        // ============================================
        // SALVAR GABARITO
        // ============================================
        async function saveGab() {
            try {
                console.log('🔄 Iniciando salvamento do gabarito...');
                const selects = document.querySelectorAll('.gab-select');
                const respostas = [];
                selects.forEach(s => { if (s.value) { respostas.push(s.value); } else { respostas.push(''); } });
                console.log('📝 Respostas coletadas:', respostas);
                const respostasValidas = respostas.filter(r => r !== '');
                if (respostasValidas.length === 0) { showToast('⚠️ Preencha pelo menos uma questão do gabarito!', 'error'); return; }
                const provaId = document.getElementById('gab-prova').value;
                if (!provaId) { showToast('❌ Selecione uma prova primeiro!', 'error'); return; }
                console.log(`📝 Salvando gabarito para prova ID: ${provaId}`);
                showToast('💾 Salvando gabarito...', 'info');
                const payload = { prova_id: parseInt(provaId), respostas: respostas };
                console.log('📤 Payload:', payload);
                const response = await fetch(`${API_URL}/api/gabaritos`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });
                console.log('📥 Status:', response.status);
                const result = await response.json();
                console.log('📥 Resposta:', result);
                if (response.ok && result.id) {
                    showToast(`✅ ${result.mensagem || 'Gabarito salvo com sucesso!'}`, 'success');
                    selects.forEach(s => { if (s.value) s.classList.add('filled'); });
                    carregarGabaritos();
                    carregarCombos();
                    carregarProvas();
                } else {
                    const erroMsg = result.erro || 'Erro desconhecido';
                    showToast(`❌ ${erroMsg}`, 'error');
                    console.error('Erro:', result);
                }
            } catch (erro) {
                console.error('❌ Erro:', erro);
                if (erro.message.includes('Failed to fetch') || erro.message.includes('ERR_CONNECTION_CLOSED')) {
                    showToast('❌ Não foi possível conectar ao servidor. Verifique se o backend está rodando.', 'error');
                } else {
                    showToast('❌ Erro ao salvar gabarito: ' + erro.message, 'error');
                }
            }
        }

        // ============================================
        // LISTA POR TURMA
        // ============================================
        async function carregarTurmasLista(escolaId) {
            const select = document.getElementById('lista-turma');
            select.innerHTML = '<option value="">Selecione a turma</option>';
            if (!escolaId) return;
            try {
                const response = await fetch(`${API_URL}/api/turmas?escola_id=${escolaId}`);
                const turmas = await response.json();
                if (turmas && !turmas.erro) {
                    turmas.forEach(t => {
                        const opt = document.createElement('option');
                        opt.value = t.id;
                        opt.textContent = t.nome + ' - ' + (t.serie || '');
                        select.appendChild(opt);
                    });
                }
            } catch (e) {
                console.error('Erro ao carregar turmas:', e);
            }
        }

        async function gerarListaTurma() {
            const escolaId = document.getElementById('lista-escola').value;
            const turmaId = document.getElementById('lista-turma').value;
            if (!turmaId) { showToast('❌ Selecione uma turma!', 'error'); return; }
            if (!escolaId) { showToast('❌ Selecione uma escola!', 'error'); return; }
            try {
                const alunosResp = await fetch(API_URL + '/api/alunos?turma_id=' + turmaId);
                const alunos = await alunosResp.json();
                const turmaResp = await fetch(API_URL + '/api/turmas');
                const turmas = await turmaResp.json();
                const turma = turmas.find(t => t.id == turmaId);
                const container = document.getElementById('lista-resultado');
                if (!container) return;
                if (!alunos || alunos.length === 0 || alunos.erro) { container.innerHTML = '<div style="text-align:center;padding:30px;color:var(--text3);">Nenhum aluno encontrado nesta turma</div>'; showToast('❌ Nenhum aluno na turma!', 'error'); return; }
                const provasResp = await fetch(API_URL + '/api/provas');
                const provas = await provasResp.json();
                const prova = provas.find(p => p.turma_id == turmaId);
                if (!prova) { container.innerHTML = '<div style="text-align:center;padding:30px;color:var(--text3);">Nenhuma prova cadastrada para esta turma</div>'; showToast('❌ Nenhuma prova para esta turma!', 'error'); return; }
                const escolaResp = await fetch(API_URL + '/api/escolas');
                const escolas = await escolaResp.json();
                const escola = escolas.find(e => e.id == turma?.escola_id);
                let html = '<div style="text-align:center;padding:12px 0 18px;border-bottom:1px solid var(--border);margin-bottom:14px;"><div style="font-size:16px;font-weight:800;">' + (escola?.nome || 'Escola') + '</div><div style="color:var(--text2);font-size:13px;margin-top:4px;">Selecione um aluno para gerar o cartão resposta</div><div style="color:var(--text3);font-size:12px;margin-top:2px;">Professor(a): ' + (turma?.professor || '—') + ' | Turno: ' + (turma?.turno || 'Manhã') + ' | Total: ' + alunos.length + ' alunos</div></div>';
                html += '<div style="display:flex;flex-direction:column;gap:8px;margin-bottom:14px;">';
                alunos.forEach(aluno => { html += '<div style="display:flex;justify-content:space-between;align-items:center;padding:10px 14px;background:var(--surface2);border-radius:8px;border:1px solid var(--border);"><div><strong>' + aluno.nome + '</strong> <span class="badge badge-blue">Nº ' + (aluno.numero_chamada || '—') + '</span></div><button class="btn btn-primary btn-sm" onclick="gerarCartaoResposta(' + escolaId + ',' + turmaId + ',' + aluno.id + ',' + prova.id + ')">📄 Gerar Cartão</button></div>'; });
                html += '</div><div style="display:grid;grid-template-columns:1fr 1fr;gap:40px;margin-top:20px;padding-top:18px;border-top:1px solid var(--border);"><div style="text-align:center;"><div style="border-top:1px solid var(--border2);padding-top:8px;font-size:12px;color:var(--text2);">Professor(a) Responsável</div></div><div style="text-align:center;"><div style="border-top:1px solid var(--border2);padding-top:8px;font-size:12px;color:var(--text2);">Diretor(a)</div></div></div>';
                container.innerHTML = html;
                showToast('📋 ' + alunos.length + ' alunos encontrados. Selecione um para gerar o cartão!', 'info');
            } catch (erro) { console.error('Erro ao gerar lista:', erro); showToast('❌ Erro: ' + erro.message, 'error'); }
        }

        // ============================================
        // GERAR CARTÃO RESPOSTA
        // ============================================
        async function gerarCartaoResposta(escolaId, turmaId, alunoId, provaId) {
            try {
                const provasResp = await fetch(API_URL + '/api/provas');
                const provas = await provasResp.json();
                const prova = provas.find(p => p.id == provaId);
                const qtdQuestoes = prova?.quantidade_questoes || 20;
                const response = await fetch(API_URL + '/api/gerar_gabarito', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ escola_id: parseInt(escolaId), turma_id: parseInt(turmaId), aluno_id: parseInt(alunoId), prova_id: parseInt(provaId), quantidade_questoes: qtdQuestoes })
                });
                if (response.ok) {
                    const html = await response.text();
                    const novaAba = window.open('', '_blank');
                    novaAba.document.write(html);
                    novaAba.document.close();
                    document.getElementById('lista-resultado').innerHTML = '<div style="background:#d4edda;color:#155724;padding:15px;border-radius:8px;text-align:center;">✅ Cartão resposta gerado com ' + qtdQuestoes + ' questões!<br><small>Uma nova aba foi aberta com a folha de respostas.<br>Clique em <strong>🖨️ IMPRIMIR</strong> ou pressione <strong>Ctrl+P</strong>.</small></div>';
                    showToast('✅ Cartão resposta com ' + qtdQuestoes + ' questões gerado!', 'success');
                } else {
                    const erro = await response.json();
                    showToast('❌ Erro ao gerar cartão: ' + (erro.erro || 'Erro desconhecido'), 'error');
                }
            } catch (erro) { console.error('Erro ao gerar cartão:', erro); showToast('❌ Erro: ' + erro.message, 'error'); }
        }

        // ============================================
        // SALVAR FUNCTIONS
        // ============================================
        async function salvarEscola() {
            const dados = { nome: document.getElementById('escola-nome').value.trim(), inep: document.getElementById('escola-inep').value.trim() || '', municipio: document.getElementById('escola-municipio').value.trim() || '', estado: document.getElementById('escola-estado').value || 'SP', telefone: document.getElementById('escola-telefone').value.trim() || '', diretor: document.getElementById('escola-diretor').value.trim() || '' };
            if (!dados.nome) { showToast('❌ Nome da escola é obrigatório!', 'error'); return; }
            try {
                const response = await fetch(API_URL + '/api/escolas', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(dados) });
                const result = await response.json();
                if (result.id) { showToast('✅ Escola "' + dados.nome + '" cadastrada!', 'success'); closeM('m-escola'); carregarDados(); carregarEscolasFiltroAlunos(); } else { showToast('❌ Erro ao cadastrar escola', 'error'); }
            } catch (erro) { showToast('❌ Erro: ' + erro.message, 'error'); }
        }

        async function salvarTurma() {
            const dados = { escola_id: parseInt(document.getElementById('turma-escola').value) || null, nome: document.getElementById('turma-nome').value.trim(), serie: document.getElementById('turma-serie').value || '1º Ano', turno: document.getElementById('turma-turno').value || 'Manhã', professor: document.getElementById('turma-professor').value.trim() || '', capacidade: parseInt(document.getElementById('turma-capacidade').value) || 35, ano_letivo: parseInt(document.getElementById('turma-ano').value) || 2025 };
            if (!dados.escola_id) { showToast('❌ Selecione uma escola!', 'error'); return; }
            if (!dados.nome) { showToast('❌ Nome da turma é obrigatório!', 'error'); return; }
            try {
                const response = await fetch(API_URL + '/api/turmas', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(dados) });
                const result = await response.json();
                if (result.id) { showToast('✅ Turma "' + dados.nome + '" cadastrada!', 'success'); closeM('m-turma'); carregarDados(); } else { showToast('❌ Erro ao cadastrar turma', 'error'); }
            } catch (erro) { showToast('❌ Erro: ' + erro.message, 'error'); }
        }

        async function salvarAluno() {
            const dados = { turma_id: parseInt(document.getElementById('aluno-turma').value) || null, nome: document.getElementById('aluno-nome').value.trim(), matricula: document.getElementById('aluno-matricula').value.trim() || '', numero_chamada: parseInt(document.getElementById('aluno-numero').value) || null, data_nascimento: document.getElementById('aluno-nascimento').value || null, genero: document.getElementById('aluno-genero').value || 'Masculino', responsavel: document.getElementById('aluno-responsavel').value.trim() || '', telefone: document.getElementById('aluno-telefone').value.trim() || '', email: document.getElementById('aluno-email').value.trim() || '', observacoes: document.getElementById('aluno-observacoes').value.trim() || '' };
            if (!dados.nome) { showToast('❌ Nome do aluno é obrigatório!', 'error'); return; }
            if (!dados.turma_id) { showToast('❌ Selecione a turma do aluno!', 'error'); return; }
            try {
                const response = await fetch(API_URL + '/api/alunos', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(dados) });
                const result = await response.json();
                if (result.id) { showToast('✅ Aluno "' + dados.nome + '" cadastrado!', 'success'); closeM('m-aluno'); carregarDados(); } else { showToast('❌ Erro ao cadastrar aluno', 'error'); }
            } catch (erro) { showToast('❌ Erro: ' + erro.message, 'error'); }
        }

        async function salvarProva() {
            const dados = { turma_id: parseInt(document.getElementById('prova-turma').value) || null, titulo: document.getElementById('prova-titulo').value.trim(), disciplina: document.getElementById('prova-disciplina').value || '', bimestre: document.getElementById('prova-bimestre').value || '', data_prova: document.getElementById('prova-data').value || null, valor_nota: parseFloat(document.getElementById('prova-nota').value) || 10, tipo_questoes: document.getElementById('prova-serie').value ? (document.getElementById('prova-serie').value.startsWith('1') ? '3' : '4') : '4', gabarito: [] };
            if (!dados.turma_id) { showToast('❌ Selecione a turma!', 'error'); return; }
            if (!dados.titulo) { showToast('❌ Título da prova é obrigatório!', 'error'); return; }
            if (!dados.data_prova) { showToast('❌ Data da prova é obrigatória!', 'error'); return; }
            try {
                const response = await fetch(API_URL + '/api/provas', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(dados) });
                const result = await response.json();
                if (result.id) { showToast('✅ Prova "' + dados.titulo + '" cadastrada!', 'success'); document.getElementById('up-ok').style.display = 'block'; carregarDados(); } else { showToast('❌ Erro ao cadastrar prova', 'error'); }
            } catch (erro) { showToast('❌ Erro: ' + erro.message, 'error'); }
        }

        async function salvarProvaModal() {
            const dados = { turma_id: parseInt(document.getElementById('modal-prova-turma').value) || null, titulo: document.getElementById('modal-prova-titulo').value.trim(), disciplina: document.getElementById('modal-prova-disciplina').value || '', bimestre: document.getElementById('modal-prova-bimestre').value || '', data_prova: document.getElementById('modal-prova-data').value || null, valor_nota: parseFloat(document.getElementById('modal-prova-valor').value) || 10, tipo_questoes: document.getElementById('modal-prova-tipo').value || '4', gabarito: [] };
            const gabInputs = document.querySelectorAll('#modal-gabarito-grid input');
            gabInputs.forEach(input => { if (input.value) dados.gabarito.push(input.value.toUpperCase()); });
            if (!dados.turma_id) { showToast('❌ Selecione a turma!', 'error'); return; }
            if (!dados.titulo) { showToast('❌ Título da prova é obrigatório!', 'error'); return; }
            if (!dados.data_prova) { showToast('❌ Data da prova é obrigatória!', 'error'); return; }
            if (dados.gabarito.length === 0) { showToast('❌ Preencha o gabarito!', 'error'); return; }
            try {
                const response = await fetch(API_URL + '/api/provas', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(dados) });
                const result = await response.json();
                if (result.id) { showToast('✅ Prova "' + dados.titulo + '" cadastrada!', 'success'); closeM('m-prova'); carregarDados(); } else { showToast('❌ Erro ao cadastrar prova', 'error'); }
            } catch (erro) { showToast('❌ Erro: ' + erro.message, 'error'); }
        }

        // ============================================
        // CÂMERA
        // ============================================
        async function abrirCamera() {
            document.getElementById('cam-modal').classList.add('show');
            try {
                if (camStream) camStream.getTracks().forEach(t => t.stop());
                camStream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: camFacing, width: { ideal: 1280 }, height: { ideal: 720 } } });
                document.getElementById('cam-video').srcObject = camStream;
            } catch (e) { showToast('❌ Câmera não disponível: ' + e.message, 'error'); fecharCamera(); }
        }

        function trocarCamera() { camFacing = camFacing === 'environment' ? 'user' : 'environment'; abrirCamera(); }
        function fecharCamera() { document.getElementById('cam-modal').classList.remove('show'); if (camStream) { camStream.getTracks().forEach(t => t.stop()); camStream = null; } }

        function capturarFoto() {
            const vid = document.getElementById('cam-video');
            const canvas = document.getElementById('cam-canvas');
            canvas.width = vid.videoWidth || 640;
            canvas.height = vid.videoHeight || 480;
            canvas.getContext('2d').drawImage(vid, 0, 0);
            const foto = canvas.toDataURL('image/jpeg', 0.9);
            fecharCamera();
            showToast('📸 Foto capturada!', 'ai');
            ultimaImagem = foto;
            processarComIA(foto);
            go('corrigir-ia');
        }

        function abrirArquivo() { document.getElementById('inp-arq').click(); }

        function processarArq(input) {
            const file = input.files[0];
            if (!file) return;
            const reader = new FileReader();
            reader.onload = e => {
                showToast('📂 Arquivo carregado!', 'ai');
                ultimaImagem = e.target.result;
                processarComIA(e.target.result);
                go('corrigir-ia');
            };
            reader.readAsDataURL(file);
        }

        // ============================================
        // IA CORREÇÃO
        // ============================================
        async function processarComIA(imagemBase64) {
            showToast('🤖 Processando...', 'ai');
            const box = document.getElementById('ia-result');
            if (box) box.style.display = 'none';
            const provaId = document.getElementById('corrigir-prova').value || 1;
            const alunoId = document.getElementById('corrigir-aluno').value || 1;
            if (!imagemBase64) { showToast('❌ Nenhuma imagem!', 'error'); return; }
            document.getElementById('ia-ultima-imagem').value = imagemBase64;
            try {
                const response = await fetch(API_URL + '/api/corrigir', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ imagem: imagemBase64, prova_id: parseInt(provaId), aluno_id: parseInt(alunoId) }) });
                const dados = await response.json();
                if (dados.erro) { showToast('❌ ' + dados.erro, 'error'); return; }
                const rd = document.getElementById('ia-resp');
                if (rd) { rd.innerHTML = dados.respostas_detectadas.map((a, i) => { const ok = a === dados.correcoes?.[i]?.gabarito; return '<span style="background:' + (ok ? 'rgba(16,185,129,.2)' : 'rgba(239,68,68,.2)') + ';border:1px solid ' + (ok ? 'rgba(16,185,129,.4)' : 'rgba(239,68,68,.4)') + ';padding:3px 8px;border-radius:6px;font-size:11px;font-weight:700;color:' + (ok ? 'var(--green)' : 'var(--red)') + ';">Q' + (i + 1) + ':' + a + '</span>'; }).join(''); }
                const cd = document.getElementById('ia-comp');
                if (cd) { cd.innerHTML = dados.respostas_detectadas.map((a, i) => { const ok = a === dados.correcoes?.[i]?.gabarito; return '<div style="text-align:center;"><div style="font-size:9px;color:var(--text3);margin-bottom:2px;">Q' + (i + 1) + '</div><div style="background:' + (ok ? 'rgba(16,185,129,.2)' : 'rgba(239,68,68,.2)') + ';border:1px solid ' + (ok ? 'rgba(16,185,129,.4)' : 'rgba(239,68,68,.4)') + ';border-radius:6px;padding:4px 2px;font-size:11px;font-weight:800;color:' + (ok ? 'var(--green)' : 'var(--red)') + ';">' + a + '</div></div>'; }).join(''); }
                document.getElementById('ia-nota').textContent = dados.nota || 0;
                document.getElementById('ia-aluno').textContent = dados.aluno || 'Aluno';
                document.getElementById('ia-turma').textContent = dados.prova || 'Prova';
                document.getElementById('confianca-badge').textContent = (dados.confianca || 0) + '% conf.';
                document.getElementById('ia-status').textContent = dados.nota >= 6 ? 'APROVADO' : 'REPROVADO';
                document.getElementById('ia-status').className = 'badge ' + (dados.nota >= 6 ? 'badge-green' : 'badge-red');

                correcaoManualData.alunoId = parseInt(alunoId);
                correcaoManualData.alunoNome = dados.aluno || 'Aluno';
                correcaoManualData.provaId = parseInt(provaId);
                correcaoManualData.provaTitulo = dados.prova || 'Prova';
                correcaoManualData.gabarito = dados.correcoes?.map(c => c.gabarito) || [];
                correcaoManualData.respostasAluno = dados.respostas_detectadas || [];
                correcaoManualData.quantidade = dados.total || 20;
                correcaoManualData.alternativas = dados.tipo_questoes === '3' ? ['A', 'B', 'C'] : ['A', 'B', 'C', 'D'];
                correcaoManualData.notaMaxima = parseFloat(document.getElementById('config-nota-max').value) || 10;
                correcaoManualData.notaMinima = parseFloat(document.getElementById('config-nota-min').value) || 5;
                correcaoManualData.valorPorQuestao = dados.valor_por_questao || (correcaoManualData.notaMaxima / correcaoManualData.quantidade);
                correcaoManualData.serie = document.getElementById('corrigir-serie').value || '1º Ano';

                if (box) box.style.display = 'block';
                showToast('✅ ' + dados.acertos + '/' + dados.total + ' acertos — Nota: ' + dados.nota, 'success');
                carregarDashboard();
                carregarResultados();
            } catch (erro) { showToast('❌ Erro na correção: ' + erro.message, 'error'); console.error(erro); }
        }

        function salvarCorrecao() { showToast('💾 Correção salva com sucesso!', 'success'); }

        // ============================================
        // CORREÇÃO MANUAL
        // ============================================
        function abrirCorrecaoManual() {
            if (!correcaoManualData.respostasAluno || correcaoManualData.respostasAluno.length === 0) {
                showToast('❌ Nenhuma correção para editar. Faça uma correção com IA primeiro!', 'error');
                return;
            }
            if (!correcaoManualData.gabarito || !Array.isArray(correcaoManualData.gabarito) || correcaoManualData.gabarito.length === 0) {
                showToast('❌ Gabarito não disponível para esta prova!', 'error');
                return;
            }
            const temGabaritoValido = correcaoManualData.gabarito.some(g => g && g.trim() !== '');
            if (!temGabaritoValido) {
                showToast('❌ Gabarito vazio ou inválido para esta prova!', 'error');
                return;
            }
            document.getElementById('cm-aluno-nome').textContent = correcaoManualData.alunoNome || 'Aluno';
            document.getElementById('cm-prova-titulo').textContent = correcaoManualData.provaTitulo || 'Prova';
            document.getElementById('cm-turma-info').textContent = correcaoManualData.serie + ' | Turma: —';
            document.getElementById('cm-data-correcao').textContent = new Date().toLocaleDateString('pt-BR');
            gerarGridCorrecaoManual();
            atualizarResumoCorrecaoManual();
            openM('m-correcao-manual');
        }

        function gerarGridCorrecaoManual() {
            const grid = document.getElementById('cm-grid');
            if (!grid) return;
            const qtd = correcaoManualData.quantidade || 20;
            const alternativas = correcaoManualData.alternativas || ['A', 'B', 'C', 'D'];
            const respostas = correcaoManualData.respostasAluno || [];
            const gabarito = correcaoManualData.gabarito || [];
            grid.innerHTML = '';
            for (let i = 0; i < qtd; i++) {
                const div = document.createElement('div');
                div.className = 'correcao-manual-item';
                const respostaAluno = (i < respostas.length) ? respostas[i] : '';
                const respostaGabarito = (i < gabarito.length) ? gabarito[i] : '';
                const isCorreto = respostaAluno && respostaGabarito && respostaAluno.toUpperCase() === respostaGabarito.toUpperCase();
                let options = '<option value="">—</option>';
                alternativas.forEach(alt => {
                    const selected = respostaAluno && respostaAluno.toUpperCase() === alt ? 'selected' : '';
                    options += `<option value="${alt}" ${selected}>${alt}</option>`;
                });
                let statusClass = '';
                let statusText = '';
                if (respostaAluno) {
                    if (isCorreto) { statusClass = 'correta'; statusText = '✅ Correto'; } else { statusClass = 'errada'; statusText = '❌ Errado'; }
                }
                div.innerHTML = `<div class="q-num">Q${i+1}</div><div class="q-resposta" style="color:${isCorreto ? 'var(--green)' : (respostaAluno ? 'var(--red)' : 'var(--text3)')}">${respostaAluno || '—'}</div><select class="q-select" data-questao="${i}" onchange="atualizarRespostaManual(this)">${options}</select><div class="q-status ${statusClass}">${statusText}</div><div style="font-size:8px;color:var(--text3);margin-top:2px;">Gabarito: ${respostaGabarito || '—'}</div>`;
                const select = div.querySelector('.q-select');
                if (select) {
                    if (isCorreto && respostaAluno) { select.className = 'q-select correta'; } else if (respostaAluno && !isCorreto) { select.className = 'q-select errada'; }
                }
                grid.appendChild(div);
            }
        }

        function atualizarRespostaManual(select) {
            const questaoIndex = parseInt(select.dataset.questao);
            const novaResposta = select.value;
            if (novaResposta) { correcaoManualData.respostasAluno[questaoIndex] = novaResposta.toUpperCase(); } else { correcaoManualData.respostasAluno[questaoIndex] = ''; }
            const item = select.closest('.correcao-manual-item');
            const qResposta = item.querySelector('.q-resposta');
            const qStatus = item.querySelector('.q-status');
            const gabarito = correcaoManualData.gabarito[questaoIndex] || '';
            const resposta = correcaoManualData.respostasAluno[questaoIndex] || '';
            const isCorreto = resposta && gabarito && resposta.toUpperCase() === gabarito.toUpperCase();
            qResposta.textContent = resposta || '—';
            qResposta.style.color = isCorreto ? 'var(--green)' : (resposta ? 'var(--red)' : 'var(--text3)');
            if (resposta) {
                if (isCorreto) { qStatus.textContent = '✅ Correto'; qStatus.className = 'q-status correta'; select.className = 'q-select correta'; } else { qStatus.textContent = '❌ Errado'; qStatus.className = 'q-status errada'; select.className = 'q-select errada'; }
            } else { qStatus.textContent = ''; qStatus.className = 'q-status'; select.className = 'q-select'; }
            atualizarResumoCorrecaoManual();
        }

        function atualizarResumoCorrecaoManual() {
            const qtd = correcaoManualData.quantidade || 20;
            const respostas = correcaoManualData.respostasAluno || [];
            const gabarito = correcaoManualData.gabarito || [];
            let acertos = 0,
                respondidas = 0;
            for (let i = 0; i < qtd; i++) {
                const resp = i < respostas.length ? respostas[i] : '';
                const gab = i < gabarito.length ? gabarito[i] : '';
                if (resp) { respondidas++; if (resp.toUpperCase() === gab.toUpperCase()) { acertos++; } }
            }
            const erros = respondidas - acertos;
            const nota = (acertos * correcaoManualData.valorPorQuestao) || 0;
            const notaFinal = Math.min(nota, correcaoManualData.notaMaxima || 10);
            const porcentagem = qtd > 0 ? Math.round((acertos / qtd) * 100) : 0;
            document.getElementById('cm-acertos').textContent = acertos;
            document.getElementById('cm-erros').textContent = erros;
            document.getElementById('cm-nota').textContent = notaFinal.toFixed(1);
            const statusBadge = document.getElementById('cm-status-badge');
            const statusAtual = document.getElementById('cm-status-atual');
            if (notaFinal >= (correcaoManualData.notaMinima || 5)) { statusBadge.textContent = '✅ APROVADO'; statusBadge.className = 'badge badge-green'; statusAtual.textContent = 'Aprovado'; statusAtual.style.color = 'var(--green)'; } else if (notaFinal >= (correcaoManualData.notaMinima || 5) * 0.8) { statusBadge.textContent = '⚠️ RECUPERAÇÃO'; statusBadge.className = 'badge badge-orange'; statusAtual.textContent = 'Recuperação'; statusAtual.style.color = 'var(--orange)'; } else { statusBadge.textContent = '❌ REPROVADO'; statusBadge.className = 'badge badge-red'; statusAtual.textContent = 'Reprovado'; statusAtual.style.color = 'var(--red)'; }
            document.getElementById('cm-porcentagem').textContent = porcentagem + '% de aproveitamento';
        }

        function preencherGabaritoCM() {
            const qtd = correcaoManualData.quantidade || 20;
            const gabarito = correcaoManualData.gabarito || [];
            for (let i = 0; i < qtd; i++) { if (i < gabarito.length && gabarito[i]) { correcaoManualData.respostasAluno[i] = gabarito[i]; } }
            gerarGridCorrecaoManual();
            atualizarResumoCorrecaoManual();
            showToast('📋 Respostas preenchidas com o gabarito!', 'success');
        }

        function limparRespostasCM() {
            const qtd = correcaoManualData.quantidade || 20;
            for (let i = 0; i < qtd; i++) { correcaoManualData.respostasAluno[i] = ''; }
            gerarGridCorrecaoManual();
            atualizarResumoCorrecaoManual();
            showToast('🗑️ Respostas limpas!', 'info');
        }

        function salvarCorrecaoManual() {
            const qtd = correcaoManualData.quantidade || 20;
            const respostas = correcaoManualData.respostasAluno || [];
            const gabarito = correcaoManualData.gabarito || [];
            let acertos = 0;
            for (let i = 0; i < qtd; i++) {
                const resp = i < respostas.length ? respostas[i] : '';
                const gab = i < gabarito.length ? gabarito[i] : '';
                if (resp && resp.toUpperCase() === gab.toUpperCase()) { acertos++; }
            }
            const nota = Math.min((acertos * correcaoManualData.valorPorQuestao), correcaoManualData.notaMaxima || 10);
            showToast('💾 Salvando correção manual...', 'info');
            const dadosCorrecao = { prova_id: correcaoManualData.provaId, aluno_id: correcaoManualData.alunoId, respostas: respostas, acertos: acertos, nota: nota, total: qtd };
            fetch(API_URL + '/api/corrigir_manual', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(dadosCorrecao) })
                .then(response => response.json())
                .then(data => {
                    if (data.sucesso) {
                        showToast('✅ Correção manual salva! Nota: ' + nota.toFixed(1), 'success');
                        closeM('m-correcao-manual');
                        const notaEl = document.getElementById('ia-nota'); if (notaEl) { notaEl.textContent = nota.toFixed(1); notaEl.style.color = nota >= 5 ? 'var(--green)' : 'var(--red)'; }
                        const statusEl = document.getElementById('ia-status'); if (statusEl) { const status = nota >= 5 ? 'APROVADO' : 'REPROVADO'; const badgeClass = nota >= 5 ? 'badge-green' : 'badge-red'; statusEl.textContent = status; statusEl.className = 'badge ' + badgeClass; }
                        const header = document.querySelector('.card-glow-green .card-header .btn-group'); if (header) { const oldBadge = header.querySelector('.badge-manual'); if (oldBadge) oldBadge.remove(); const manualBadge = document.createElement('span'); manualBadge.className = 'badge badge-orange badge-manual'; manualBadge.textContent = '✏️ Manual'; header.appendChild(manualBadge); }
                        const respContainer = document.getElementById('ia-resp'); if (respContainer && respostas.length > 0) { const gabarito = correcaoManualData.gabarito || []; respContainer.innerHTML = respostas.map((resp, i) => { const ok = resp === gabarito[i]; return '<span style="background:' + (ok ? 'rgba(16,185,129,.2)' : 'rgba(239,68,68,.2)') + ';border:1px solid ' + (ok ? 'rgba(16,185,129,.4)' : 'rgba(239,68,68,.4)') + ';padding:3px 8px;border-radius:6px;font-size:11px;font-weight:700;color:' + (ok ? 'var(--green)' : 'var(--red)') + ';">Q' + (i + 1) + ':' + resp + '</span>'; }).join(''); }
                        const compContainer = document.getElementById('ia-comp'); if (compContainer && respostas.length > 0) { const gabarito = correcaoManualData.gabarito || []; compContainer.innerHTML = respostas.map((resp, i) => { const ok = resp === gabarito[i]; return '<div style="text-align:center;"><div style="font-size:9px;color:var(--text3);margin-bottom:2px;">Q' + (i + 1) + '</div><div style="background:' + (ok ? 'rgba(16,185,129,.2)' : 'rgba(239,68,68,.2)') + ';border:1px solid ' + (ok ? 'rgba(16,185,129,.4)' : 'rgba(239,68,68,.4)') + ';border-radius:6px;padding:4px 2px;font-size:11px;font-weight:800;color:' + (ok ? 'var(--green)' : 'var(--red)') + ';">' + resp + '</div></div>'; }).join(''); }
                        const confiancaEl = document.getElementById('confianca-badge'); if (confiancaEl) { confiancaEl.textContent = '100% conf.'; }
                        setTimeout(() => { carregarResultados(); carregarDashboard(); carregarUltimasCorrecoes(); }, 500);
                    } else { showToast('❌ Erro ao salvar: ' + (data.erro || 'Erro desconhecido'), 'error'); }
                })
                .catch(erro => { showToast('❌ Erro ao salvar correção: ' + erro.message, 'error'); console.error('Erro ao salvar correção manual:', erro); });
        }

        // ============================================
        // RESULTADOS COM FILTROS
        // ============================================
        async function carregarFiltrosResultados() {
            try {
                const respEscolas = await fetch(API_URL + '/api/escolas');
                const escolas = await respEscolas.json();
                const selectEscola = document.getElementById('filtro-escola');
                if (selectEscola && escolas && !escolas.erro) {
                    const current = selectEscola.value;
                    selectEscola.innerHTML = '<option value="">Todas as escolas</option>';
                    escolas.forEach(e => { const opt = document.createElement('option'); opt.value = e.id; opt.textContent = e.nome; selectEscola.appendChild(opt); });
                    if (current) selectEscola.value = current;
                }
                const respTurmas = await fetch(API_URL + '/api/turmas');
                const turmas = await respTurmas.json();
                const selectTurma = document.getElementById('filtro-turma');
                if (selectTurma && turmas && !turmas.erro) {
                    const current = selectTurma.value;
                    selectTurma.innerHTML = '<option value="">Todas as turmas</option>';
                    turmas.forEach(t => { const opt = document.createElement('option'); opt.value = t.id; opt.textContent = t.nome + ' - ' + (t.serie || ''); selectTurma.appendChild(opt); });
                    if (current) selectTurma.value = current;
                }
            } catch (erro) { console.error('Erro ao carregar filtros:', erro); }
        }

        async function carregarTurmasPorEscola(escolaId) {
            const selectTurma = document.getElementById('filtro-turma');
            if (!selectTurma) return;
            selectTurma.innerHTML = '<option value="">Todas as turmas</option>';
            try {
                const respTurmas = await fetch(API_URL + '/api/turmas');
                const turmas = await respTurmas.json();
                if (turmas && !turmas.erro) {
                    const turmasFiltradas = escolaId && escolaId !== '' ? turmas.filter(t => t.escola_id == escolaId) : turmas;
                    turmasFiltradas.forEach(t => { const opt = document.createElement('option'); opt.value = t.id; opt.textContent = t.nome + ' - ' + (t.serie || ''); selectTurma.appendChild(opt); });
                }
            } catch (erro) { console.error('Erro ao carregar turmas:', erro); }
            carregarResultadosComFiltros();
        }

        async function carregarResultadosComFiltros() {
            try {
                const escolaId = document.getElementById('filtro-escola').value;
                const serie = document.getElementById('filtro-serie').value;
                const turmaId = document.getElementById('filtro-turma').value;
                let url = API_URL + '/api/historico';
                const params = new URLSearchParams();
                if (escolaId && escolaId !== '') params.append('escola', escolaId);
                if (serie && serie !== '') params.append('serie', serie);
                if (turmaId && turmaId !== '') params.append('turma', turmaId);
                if (params.toString()) url += '?' + params.toString();
                const response = await fetch(url);
                const historico = await response.json();
                const tbody = document.getElementById('tb-resultados-filtrado');
                if (!tbody) return;
                if (!historico || historico.length === 0 || historico.erro) {
                    tbody.innerHTML = '<tr><td colspan="10" style="text-align:center;padding:30px;color:var(--text3);">Nenhuma correção encontrada com os filtros selecionados</td></tr>';
                    document.getElementById('res-total-filtrado').textContent = '0';
                    document.getElementById('res-Habilidades-filtrado').textContent = '0';
                    document.getElementById('res-recuperacao-filtrado').textContent = '0';
                    document.getElementById('res-media-filtrado').textContent = '0';
                    atualizarGraficosConceitos([]);
                    return;
                }
                const dadosCorrigidos = historico.map(item => ({ ...item, nota: parseFloat(item.nota) || 0, acertos: parseInt(item.acertos) || 0, total_questoes: parseInt(item.total_questoes) || 20 }));
                let total = dadosCorrigidos.length;
                let Habilidades = dadosCorrigidos.filter(c => c.nota >= 5).length;
                let recuperacao = dadosCorrigidos.filter(c => c.nota >= 3 && c.nota < 5).length;
                let media = total > 0 ? (dadosCorrigidos.reduce((s, c) => s + c.nota, 0) / total) : 0;
                document.getElementById('res-total-filtrado').textContent = total;
                document.getElementById('res-Habilidades-filtrado').textContent = Habilidades;
                document.getElementById('res-recuperacao-filtrado').textContent = recuperacao;
                document.getElementById('res-media-filtrado').textContent = media.toFixed(1);
                document.getElementById('total-alunos-tabela').textContent = total + ' alunos';
                dadosCorrigidos.sort((a, b) => b.nota - a.nota);
                atualizarGraficosConceitos(dadosCorrigidos);
                if (total === 0) { tbody.innerHTML = '<tr><td colspan="10" style="text-align:center;padding:30px;color:var(--text3);">Nenhum aluno encontrado com os filtros selecionados</td></tr>'; return; }
                tbody.innerHTML = dadosCorrigidos.map((item, index) => {
                    const medalha = index === 0 ? '🥇' : index === 1 ? '🥈' : index === 2 ? '🥉' : (index + 1);
                    const nota = item.nota || 0;
                    const acertos = item.acertos || 0;
                    const totalQuestoes = item.total_questoes || 20;
                    const porcentagem = totalQuestoes > 0 ? Math.round((acertos / totalQuestoes) * 100) : 0;
                    const conceito = calcularConceito(porcentagem);
                    const status = nota >= 5 ? 'Aprovado' : (nota >= 3 ? 'Recomposição da Aprendizagem' : 'Reprovado');
                    const badge = nota >= 5 ? 'badge-green' : (nota >= 3 ? 'badge-orange' : 'badge-red');
                    const cor = nota >= 5 ? 'var(--green)' : (nota >= 3 ? 'var(--orange)' : 'var(--red)');
                    const badgeConceito = `badge-conceito-${conceito.toLowerCase().replace(' ', '-')}`;
                    const nome = item.aluno_nome || 'Aluno';
                    const serieAluno = item.serie || '—';
                    const correcaoId = item.id;
                    return '<tr data-correcao-id="' + correcaoId + '">' +
                        '<td>' + medalha + '</td>' +
                        '<td>' + (index + 1) + '</td>' +
                        '<td><strong>' + nome + '</strong></td>' +
                        '<td><span class="badge badge-purple">' + serieAluno + '</span></td>' +
                        '<td>' + acertos + '</td>' +
                        '<td><strong>' + porcentagem + '%</strong></td>' +
                        '<td><span class="badge ' + badgeConceito + '">' + conceito + '</span></td>' +
                        '<td><strong style="color:' + cor + ';">' + nota.toFixed(1) + '</strong></td>' +
                        '<td><span class="badge ' + badge + '">' + status + '</span></td>' +
                        '<td><button class="btn btn-outline btn-sm" style="color:var(--red);border-color:rgba(239,68,68,0.3);" onclick="excluirCorrecao(this, ' + correcaoId + ', \'' + nome.replace(/'/g, "\\'") + '\')" title="Excluir esta correção">🗑️</button></td></tr>';
                }).join('');
            } catch (erro) {
                console.error('Erro ao carregar resultados:', erro);
                const tbody = document.getElementById('tb-resultados-filtrado');
                if (tbody) { tbody.innerHTML = '<tr><td colspan="10" style="text-align:center;padding:30px;color:var(--text3);">Erro ao carregar resultados</td></tr>'; }
            }
        }

        function limparFiltrosResultados() {
            document.getElementById('filtro-escola').value = '';
            document.getElementById('filtro-serie').value = '';
            const selectTurma = document.getElementById('filtro-turma');
            selectTurma.innerHTML = '<option value="">Todas as turmas</option>';
            fetch(API_URL + '/api/turmas').then(r => r.json()).then(turmas => {
                if (turmas && !turmas.erro) { turmas.forEach(t => { const opt = document.createElement('option'); opt.value = t.id; opt.textContent = t.nome + ' - ' + (t.serie || ''); selectTurma.appendChild(opt); }); }
                carregarResultadosComFiltros();
            }).catch(e => console.error('Erro ao recarregar turmas:', e));
        }

        // ============================================
        // EXCLUIR CORREÇÃO DO HISTÓRICO
        // ============================================
        async function excluirCorrecao(btn, correcaoId, alunoNome) {
            const row = btn.closest('tr');
            if (!row) return;
            if (!correcaoId) { showToast('❌ Não foi possível identificar a correção', 'error'); return; }
            if (!confirm(`Deseja excluir esta correção do aluno "${alunoNome}"? Esta ação não pode ser desfeita.`)) return;
            try {
                const response = await fetch(`${API_URL}/api/historico/${correcaoId}`, { method: 'DELETE' });
                const result = await response.json();
                if (response.ok) {
                    row.style.transition = 'all 0.3s ease';
                    row.style.opacity = '0';
                    row.style.transform = 'scale(0.95)';
                    setTimeout(() => { row.remove(); atualizarContadoresAposExclusao(); showToast(`🗑️ Correção de "${alunoNome}" excluída do histórico`, 'success'); }, 300);
                } else { showToast('❌ Erro ao excluir: ' + (result.erro || 'Erro desconhecido'), 'error'); }
            } catch (error) { console.error('Erro ao excluir correção:', error); showToast('❌ Erro ao conectar ao servidor', 'error'); }
        }

        function atualizarContadoresAposExclusao() {
            const tbody = document.getElementById('tb-resultados-filtrado');
            if (!tbody) return;
            const rows = tbody.querySelectorAll('tr:not(.deleted)');
            const total = rows.length;
            document.getElementById('total-alunos-tabela').textContent = total + ' alunos';
            let Habilidades = 0,
                recuperacao = 0,
                somaNotas = 0;
            rows.forEach(row => {
                const cells = row.querySelectorAll('td');
                if (cells.length >= 10) {
                    const statusText = cells[8]?.textContent?.trim() || '';
                    const notaText = cells[7]?.textContent?.trim() || '0';
                    const nota = parseFloat(notaText.replace(',', '.')) || 0;
                    if (statusText === 'Aprovado') Habilidades++;
                    if (statusText === 'Recomposição da Aprendizagem') recuperacao++;
                    somaNotas += nota;
                }
            });
            const media = total > 0 ? (somaNotas / total) : 0;
            document.getElementById('res-total-filtrado').textContent = total;
            document.getElementById('res-Habilidades-filtrado').textContent = Habilidades;
            document.getElementById('res-recuperacao-filtrado').textContent = recuperacao;
            document.getElementById('res-media-filtrado').textContent = media.toFixed(1);
            const dadosAtuais = [];
            rows.forEach(row => {
                const cells = row.querySelectorAll('td');
                if (cells.length >= 6) {
                    const acertos = parseInt(cells[4]?.textContent) || 0;
                    const totalQuestoes = 20;
                    dadosAtuais.push({ acertos: acertos, total_questoes: totalQuestoes });
                }
            });
            atualizarGraficosConceitos(dadosAtuais);
        }

        // ============================================
        // FUNÇÃO PARA CALCULAR CONCEITO
        // ============================================
        function calcularConceito(porcentagem) {
            if (porcentagem <= 40) return 'Baixo';
            if (porcentagem <= 60) return 'Médio Baixo';
            if (porcentagem <= 80) return 'Médio Alto';
            return 'Alto';
        }

        // ============================================
        // ATUALIZAR GRÁFICOS DE CONCEITOS
        // ============================================
        function atualizarGraficosConceitos(dados) {
            const conceitos = { 'Baixo': 0, 'Médio Baixo': 0, 'Médio Alto': 0, 'Alto': 0 };
            dados.forEach(item => {
                const totalQuestoes = item.total_questoes || 20;
                const porcentagem = totalQuestoes > 0 ? Math.round((item.acertos / totalQuestoes) * 100) : 0;
                const conceito = calcularConceito(porcentagem);
                conceitos[conceito] = (conceitos[conceito] || 0) + 1;
            });
            const total = dados.length || 1;
            const cores = { 'Baixo': { bg: '#ef4444' }, 'Médio Baixo': { bg: '#f59e0b' }, 'Médio Alto': { bg: '#3b82f6' }, 'Alto': { bg: '#10b981' } };
            ['Baixo', 'Médio Baixo', 'Médio Alto', 'Alto'].forEach(conceito => {
                const count = conceitos[conceito] || 0;
                const pct = total > 0 ? (count / total) * 100 : 0;
                const countEl = document.getElementById(`conceito-${conceito.toLowerCase().replace(' ', '-')}-count`);
                const barEl = document.getElementById(`conceito-${conceito.toLowerCase().replace(' ', '-')}-bar`);
                if (countEl) countEl.textContent = count;
                if (barEl) {
                    barEl.style.width = Math.max(pct, 0) + '%';
                    barEl.style.background = `linear-gradient(90deg, ${cores[conceito].bg}, ${cores[conceito].bg}dd)`;
                }
            });
            atualizarDonut(conceitos, total);
        }

        // ============================================
        // DONUT CHART
        // ============================================
        function atualizarDonut(conceitos, total) {
            const canvas = document.getElementById('donut-chart');
            if (!canvas) return;
            const ctx = canvas.getContext('2d');
            const width = canvas.width,
                height = canvas.height;
            const centerX = width / 2,
                centerY = height / 2;
            const radius = Math.min(width, height) / 2 - 20;
            const innerRadius = radius * 0.6;
            ctx.clearRect(0, 0, width, height);
            const labels = ['Baixo', 'Médio Baixo', 'Médio Alto', 'Alto'];
            const colors = ['#ef4444', '#f59e0b', '#3b82f6', '#10b981'];
            const values = labels.map(l => conceitos[l] || 0);
            document.getElementById('donut-total').textContent = total;
            const totalVal = values.reduce((a, b) => a + b, 0) || 1;
            const pcts = values.map(v => (v / totalVal) * 100);
            document.getElementById('donut-baixo-pct').textContent = pcts[0].toFixed(1) + '%';
            document.getElementById('donut-medio-baixo-pct').textContent = pcts[1].toFixed(1) + '%';
            document.getElementById('donut-medio-alto-pct').textContent = pcts[2].toFixed(1) + '%';
            document.getElementById('donut-alto-pct').textContent = pcts[3].toFixed(1) + '%';
            let startAngle = -Math.PI / 2;
            values.forEach((value, index) => {
                if (value === 0) return;
                const sliceAngle = (value / totalVal) * 2 * Math.PI;
                const endAngle = startAngle + sliceAngle;
                ctx.beginPath();
                ctx.arc(centerX, centerY, radius, startAngle, endAngle);
                ctx.arc(centerX, centerY, innerRadius, endAngle, startAngle, true);
                ctx.closePath();
                ctx.fillStyle = colors[index];
                ctx.fill();
                ctx.strokeStyle = 'var(--bg)';
                ctx.lineWidth = 2;
                ctx.stroke();
                startAngle = endAngle;
            });
            ctx.beginPath();
            ctx.arc(centerX, centerY, radius, 0, 2 * Math.PI);
            ctx.strokeStyle = 'var(--border2)';
            ctx.lineWidth = 2;
            ctx.stroke();
            ctx.beginPath();
            ctx.arc(centerX, centerY, innerRadius, 0, 2 * Math.PI);
            ctx.strokeStyle = 'var(--border2)';
            ctx.lineWidth = 2;
            ctx.stroke();
        }

        // ============================================
        // EXPORTAR FUNCTIONS
        // ============================================
        function exportarResultadosFiltrados() {
            showToast('📥 Exportando resultados filtrados...', 'info');
            const tbody = document.getElementById('tb-resultados-filtrado');
            if (!tbody) return;
            let csv = 'Posição,Número,Nome,Série,Acertos,%,Conceito,Nota,Status\n';
            tbody.querySelectorAll('tr').forEach(row => {
                const cells = row.querySelectorAll('td');
                if (cells.length >= 9) {
                    csv += cells[0].textContent.trim() + ',' + cells[1].textContent.trim() + ',' + cells[2].textContent.trim() + ',' + cells[3].textContent.trim() + ',' + cells[4].textContent.trim() + ',' + cells[5].textContent.trim() + ',' + cells[6].textContent.trim() + ',' + cells[7].textContent.trim() + ',' + cells[8].textContent.trim() + '\n';
                }
            });
            const blob = new Blob(['\uFEFF' + csv], { type: 'text/csv;charset=utf-8;' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = 'resultados_filtrados.csv';
            a.click();
            URL.revokeObjectURL(url);
            showToast('✅ Resultados exportados!', 'success');
        }

        function exportarAlunosCSV() {
            showToast('📤 Exportando alunos...', 'info');
            fetch(API_URL + '/api/alunos').then(r => r.json()).then(alunos => {
                if (!alunos || alunos.length === 0) { showToast('⚠️ Nenhum aluno para exportar', 'error'); return; }
                let csv = 'Nº,Matrícula,Nome,Série,Turma, Escola,Data Nasc.\n';
                alunos.forEach(a => { csv += (a.numero_chamada || '') + ',' + (a.matricula || '') + ',' + a.nome + ',' + (a.turma_serie || '') + ',' + (a.turma_nome || '') + ',' + (a.escola_nome || '') + ',' + (a.data_nascimento || '') + '\n'; });
                const blob = new Blob([csv], { type: 'text/csv' });
                const url = URL.createObjectURL(blob);
                const a = document.createElement('a');
                a.href = url;
                a.download = 'alunos.csv';
                a.click();
                URL.revokeObjectURL(url);
                showToast('✅ Alunos exportados!', 'success');
            }).catch(e => { showToast('❌ Erro ao exportar', 'error'); console.error(e); });
        }

        function exportarRelatorio() { showToast('📥 Exportando relatório...', 'info'); window.print(); }
        function exportarRelatorioAluno() { showToast('📥 Exportando relatório do aluno...', 'info'); window.print(); }
        function exportarRelatorioEscola() {
            showToast('📥 Exportando relatório por escola...', 'info');
            const tbody = document.getElementById('tb-rel-escola');
            if (!tbody) return;
            let csv = 'Escola,Turmas,Alunos,Média,Aprovação\n';
            tbody.querySelectorAll('tr').forEach(row => {
                const cells = row.querySelectorAll('td');
                if (cells.length >= 5) { csv += cells[0].textContent.trim() + ',' + cells[1].textContent.trim() + ',' + cells[2].textContent.trim() + ',' + cells[3].textContent.trim() + ',' + cells[4].textContent.trim() + '\n'; }
            });
            const blob = new Blob([csv], { type: 'text/csv' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = 'relatorio_escolas.csv';
            a.click();
            URL.revokeObjectURL(url);
            showToast('✅ Relatório exportado!', 'success');
        }

        // ============================================
        // BUSCAR RELATÓRIO DO ALUNO
        // ============================================
        function buscarRelatorioAluno() {
            const alunoId = document.getElementById('rel-aluno-select').value;
            if (!alunoId) { showToast('❌ Selecione um aluno!', 'error'); return; }
            showToast('🔍 Buscando histórico do aluno...', 'info');
            const tbody = document.getElementById('rel-aluno-historico');
            if (tbody) { tbody.innerHTML = '<tr><td colspan="4" style="text-align:center;padding:20px;color:var(--text3);">Carregando histórico...</td></tr>'; }
            fetch(API_URL + '/api/historico').then(r => r.json()).then(historico => {
                const filtrado = historico.filter(h => h.aluno_id == alunoId);
                if (filtrado.length === 0) { tbody.innerHTML = '<tr><td colspan="4" style="text-align:center;padding:20px;color:var(--text3);">Nenhuma correção encontrada</td></tr>'; return; }
                tbody.innerHTML = filtrado.map(h => { const status = h.nota >= 6 ? 'Aprovado' : 'Reprovado'; const badge = h.nota >= 6 ? 'badge-green' : 'badge-red'; return '<tr><td>' + h.prova_titulo + '</td><td>' + (h.data_correcao ? new Date(h.data_correcao).toLocaleDateString() : '—') + '</td><td><strong style="color:' + (h.nota >= 6 ? 'var(--green)' : 'var(--red)') + ';">' + h.nota + '</strong></td><td><span class="badge ' + badge + '">' + status + '</span></td></tr>'; }).join('');
            }).catch(e => { tbody.innerHTML = '<tr><td colspan="4" style="text-align:center;padding:20px;color:var(--text3);">Erro ao carregar histórico</td></tr>'; console.error(e); });
        }

        // ============================================
        // TEXTO IA
        // ============================================
        function prevTexto(input) {
            const file = input.files[0];
            if (!file) return;
            const reader = new FileReader();
            reader.onload = e => { document.getElementById('txt-img-prev').style.display = 'block'; document.getElementById('txt-img').src = e.target.result; };
            reader.readAsDataURL(file);
        }

        async function avaliarTexto() {
            const texto = document.getElementById('txt-aluno').value;
            const alunoId = document.getElementById('txt-aluno-select').value;
            if (!texto || texto.trim().length < 5) { showToast('❌ Digite um texto com pelo menos 5 caracteres!', 'error'); return; }
            document.getElementById('txt-waiting').style.display = 'none';
            document.getElementById('txt-loading').style.display = 'block';
            document.getElementById('txt-res').style.display = 'none';
            const pb = document.getElementById('txt-pb');
            let p = 0;
            const iv = setInterval(() => {
                p += Math.random() * 12;
                if (p > 100) p = 100;
                if (pb) pb.style.width = p + '%';
                if (p >= 100) { clearInterval(iv); processarAvaliacaoTexto(texto, alunoId); }
            }, 120);
        }

        async function processarAvaliacaoTexto(texto, alunoId) {
            try {
                const response = await fetch(API_URL + '/api/corrigir_redacao', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ texto: texto, aluno_id: alunoId || null }) });
                const dados = await response.json();
                document.getElementById('txt-loading').style.display = 'none';
                document.getElementById('txt-res').style.display = 'block';
                if (dados.erro) { showToast('❌ ' + dados.erro, 'error'); return; }
                document.getElementById('txt-nota').textContent = dados.nota || 0;
                document.getElementById('txt-status').textContent = dados.nota >= 6 ? 'APROVADO' : 'REPROVADO';
                document.getElementById('txt-status').className = 'badge ' + (dados.nota >= 6 ? 'badge-green' : 'badge-red');
                if (dados.metricas) {
                    document.getElementById('c-coe').textContent = dados.metricas.nota_coerencia || 0;
                    document.getElementById('c-tema').textContent = dados.metricas.nota_estrutura || 0;
                    document.getElementById('c-ort').textContent = dados.metricas.nota_gramatica || 0;
                    document.getElementById('c-voc').textContent = dados.metricas.nota_vocabulario || 0;
                    document.getElementById('b-coe').style.width = ((dados.metricas.nota_coerencia || 0) / 10 * 100) + '%';
                    document.getElementById('b-tema').style.width = ((dados.metricas.nota_estrutura || 0) / 10 * 100) + '%';
                    document.getElementById('b-ort').style.width = ((dados.metricas.nota_gramatica || 0) / 10 * 100) + '%';
                    document.getElementById('b-voc').style.width = ((dados.metricas.nota_vocabulario || 0) / 10 * 100) + '%';
                }
                const fb = document.getElementById('txt-fb');
                if (fb) fb.innerHTML = dados.feedback || 'Feedback gerado automaticamente.';
                if (alunoId) {
                    try {
                        const respAlunos = await fetch(API_URL + '/api/alunos');
                        const alunos = await respAlunos.json();
                        const aluno = alunos.find(a => a.id == alunoId);
                        document.getElementById('txt-aluno-nome').textContent = aluno ? aluno.nome : '—';
                    } catch (e) {}
                }
                showToast('✅ Avaliação concluída!', 'success');
            } catch (erro) { document.getElementById('txt-loading').style.display = 'none'; showToast('❌ Erro: ' + erro.message, 'error'); }
        }

        function salvarAvaliacaoTexto() { showToast('💾 Avaliação salva com sucesso!', 'success'); }

        // ============================================
        // USUÁRIOS
        // ============================================
        async function carregarUsuarios() {
            try {
                const response = await fetch(API_URL + '/api/usuarios');
                const usuarios = await response.json();
                const tbody = document.getElementById('tb-usuarios');
                if (!tbody) return;
                if (!usuarios || usuarios.length === 0 || usuarios.erro) {
                    tbody.innerHTML = '<tr><td colspan="4" style="text-align:center;padding:20px;color:var(--text3);">Nenhum usuário cadastrado</td></tr>';
                    return;
                }
                tbody.innerHTML = usuarios.map(u => {
                    const perfilBadge = u.perfil === 'admin' ? 'badge-orange' : 'badge-blue';
                    const statusBadge = u.ativo ? 'badge-green' : 'badge-red';
                    const statusText = u.ativo ? 'Ativo' : 'Inativo';
                    const isAdmin = u.username === 'admin';
                    return '<tr data-id="' + u.id + '" data-username="' + u.username + '">' +
                        '<td><strong>' + u.username + '</strong><br><small style="color:var(--text3);font-size:10px;">' + (u.nome || '') + '</small></td>' +
                        '<td><span class="badge ' + perfilBadge + '">' + (u.perfil === 'admin' ? 'Admin' : 'Usuário') + '</span></td>' +
                        '<td><span class="badge ' + statusBadge + '">' + statusText + '</span></td>' +
                        '<td>' +
                        '<div class="btn-group">' +
                        (isAdmin ? '<span style="font-size:10px;color:var(--text3);">Sistema</span>' : '<button class="btn btn-outline btn-sm" onclick="editarUsuario(' + u.id + ')">✏️</button><button class="btn-del" onclick="excluirUsuario(' + u.id + ', \'' + u.username + '\')">🗑️</button>') +
                        '</div>' +
                        '</td></tr>';
                }).join('');
            } catch (erro) { console.error('Erro ao carregar usuários:', erro); }
        }

        async function excluirUsuario(id, username) {
            if (username === 'admin') { showToast('⚠️ Não é possível excluir o usuário administrador principal!', 'error'); return; }
            if (!confirm('Excluir o usuário "' + username + '"? Esta ação não pode ser desfeita.')) return;
            try {
                const response = await fetch(API_URL + '/api/usuarios/' + id, { method: 'DELETE' });
                if (response.ok) { showToast('🗑️ Usuário "' + username + '" excluído!', 'error'); carregarUsuarios(); } else { const erro = await response.json(); showToast('Erro: ' + (erro.erro || 'Erro desconhecido'), 'error'); }
            } catch (erro) { showToast('Erro ao excluir: ' + erro.message, 'error'); }
        }

        function editarUsuario(id) { showToast('✏️ Editando usuário ID ' + id + '...', 'info'); }

        function abrirModalUsuario() {
            document.getElementById('usuario-nome').value = '';
            document.getElementById('usuario-username').value = '';
            document.getElementById('usuario-senha').value = '';
            document.getElementById('usuario-email').value = '';
            document.getElementById('usuario-perfil').value = 'usuario';
            document.getElementById('usuario-ativo').checked = true;
            openM('m-usuario');
        }

        async function salvarUsuario() {
            const nome = document.getElementById('usuario-nome').value.trim();
            const username = document.getElementById('usuario-username').value.trim();
            const senha = document.getElementById('usuario-senha').value.trim();
            const email = document.getElementById('usuario-email').value.trim();
            const perfil = document.getElementById('usuario-perfil').value;
            const ativo = document.getElementById('usuario-ativo').checked;
            if (!nome) { showToast('❌ Nome do usuário é obrigatório!', 'error'); return; }
            if (!username) { showToast('❌ Usuário (login) é obrigatório!', 'error'); return; }
            if (username.length < 3) { showToast('❌ Usuário deve ter pelo menos 3 caracteres!', 'error'); return; }
            if (!senha) { showToast('❌ Senha é obrigatória!', 'error'); return; }
            if (senha.length < 4) { showToast('❌ Senha deve ter pelo menos 4 caracteres!', 'error'); return; }
            if (email && !email.includes('@')) { showToast('❌ E-mail inválido!', 'error'); return; }
            try {
                const response = await fetch(API_URL + '/api/usuarios', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ nome: nome, username: username, senha: senha, email: email, perfil: perfil, ativo: ativo })
                });
                const result = await response.json();
                if (result.id) { showToast('✅ Usuário "' + username + '" criado com sucesso!', 'success'); closeM('m-usuario'); carregarUsuarios(); carregarDados(); } else { showToast('❌ Erro ao criar usuário: ' + (result.erro || 'Erro desconhecido'), 'error'); }
            } catch (erro) { showToast('❌ Erro ao salvar: ' + erro.message, 'error'); console.error('Erro ao salvar usuário:', erro); }
        }

        // ============================================
        // FUNÇÕES AUXILIARES
        // ============================================
        function switchTab(idx, btn) {
            const parent = btn.closest('.tab-nav');
            if (parent) { parent.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active')); btn.classList.add('active'); }
            const card = btn.closest('.card');
            if (card) { card.querySelectorAll('.tab-c').forEach((tc, i) => { tc.style.display = i === idx ? 'block' : 'none'; }); }
        }

        function openM(id) { document.getElementById(id).classList.add('show'); if (id === 'm-turma' || id === 'm-aluno') carregarCombos(); if (id === 'm-prova') { carregarCombos(); const tipo = document.getElementById('modal-prova-tipo').value; gerarGabaritoModal(tipo); } }
        function closeM(id) { document.getElementById(id).classList.remove('show'); }
        document.querySelectorAll('.modal-overlay').forEach(m => { m.addEventListener('click', e => { if (e.target === m) m.classList.remove('show'); }); });

        function gerarGabaritoModal(tipo) {
            const grid = document.getElementById('modal-gabarito-grid');
            if (!grid) return;
            const numQuestoes = 20;
            const alts = tipo == '3' ? ['A', 'B', 'C'] : ['A', 'B', 'C', 'D'];
            grid.innerHTML = '';
            for (let i = 1; i <= numQuestoes; i++) {
                const input = document.createElement('input');
                input.type = 'text';
                input.maxLength = 1;
                input.style.width = '40px';
                input.style.height = '35px';
                input.style.textAlign = 'center';
                input.style.background = 'var(--bg2)';
                input.style.border = '1.5px solid var(--border2)';
                input.style.borderRadius = '6px';
                input.style.color = 'var(--text)';
                input.style.fontWeight = 'bold';
                input.style.fontSize = '14px';
                input.style.textTransform = 'uppercase';
                input.placeholder = i;
                input.title = 'Questão ' + i;
                input.addEventListener('input', function() { this.value = this.value.toUpperCase().replace(/[^A-D]/g, ''); if (this.value && !alts.includes(this.value)) this.value = ''; });
                grid.appendChild(input);
            }
        }

        function excluir(btn, tipo, nome) {
            const row = btn.closest('tr');
            delTarget = { row, tipo, nome };
            document.getElementById('del-nome-txt').textContent = '"' + nome + '"';
            document.getElementById('del-modal').classList.add('show');
        }
        function cancelarDel() { document.getElementById('del-modal').classList.remove('show'); delTarget = null; }
        function confirmarDel() {
            document.getElementById('del-modal').classList.remove('show');
            if (!delTarget) return;
            const { row, tipo, nome } = delTarget;
            row.classList.add('deleting');
            setTimeout(() => { row.remove(); showToast('🗑️ ' + tipo.charAt(0).toUpperCase() + tipo.slice(1) + ' "' + nome + '" excluído(a).', 'error'); delTarget = null; renumerarTabela(row.closest('tbody')); }, 350);
        }

        function renumerarTabela(tbody) {
            if (!tbody) return;
            tbody.querySelectorAll('tr').forEach((tr, i) => {
                const badge = tr.querySelector('.badge-blue, .badge-gray');
                if (badge) {
                    const num = String(i + 1).padStart(2, '0');
                    if (badge.textContent.match(/^\d+$/)) badge.textContent = num;
                }
            });
        }

        function filtrarTabela(input, tbodyId) {
            const val = input.value.toLowerCase();
            document.querySelectorAll('#' + tbodyId + ' tr').forEach(row => { row.style.display = row.textContent.toLowerCase().includes(val) ? '' : 'none'; });
        }

        function filtrarSerie(sel) {
            const val = sel.value;
            document.querySelectorAll('#tb-turmas tr').forEach(row => { row.style.display = (!val || row.dataset.serie === val) ? '' : 'none'; });
        }

        function showToast(msg, type) {
            type = type || 'info';
            const c = document.getElementById('toast-c');
            const t = document.createElement('div');
            t.className = 'toast toast-' + type;
            const icons = { info: 'ℹ️', success: '✅', error: '❌', ai: '🤖' };
            t.innerHTML = '<span>' + (icons[type] || 'ℹ️') + '</span><span>' + msg + '</span>';
            c.appendChild(t);
            setTimeout(() => { t.style.opacity = '0'; t.style.transition = 'opacity .3s'; setTimeout(() => t.remove(), 300); }, 3200);
        }

        function simUpload() { setTimeout(() => { document.getElementById('up-ok').style.display = 'block'; showToast('✅ Arquivo enviado!', 'success'); }, 600); }

        function atualizarInfoAlts() {
            const s = document.getElementById('prova-serie');
            const info = document.getElementById('info-alts');
            if (!s || !info) return;
            const is1 = s.value.startsWith('1');
            info.textContent = is1 ? 'ℹ️ 1º Ano — Gabarito com 3 alternativas: A, B, C' : 'ℹ️ ' + s.value + ' — Gabarito com 4 alternativas: A, B, C, D';
            info.style.color = is1 ? '#a78bfa' : 'var(--blue)';
            info.style.borderColor = is1 ? 'rgba(139,92,246,.25)' : 'rgba(59,130,246,.25)';
            info.style.background = is1 ? 'rgba(139,92,246,.07)' : 'rgba(59,130,246,.07)';
        }

        function carregarTurmasProva() {
            const escolaId = document.getElementById('prova-escola').value;
            if (!escolaId) return;
            const select = document.getElementById('prova-turma');
            select.innerHTML = '<option value="">Selecione a turma</option>';
            fetch(API_URL + '/api/turmas?escola_id=' + escolaId).then(r => r.json()).then(turmas => {
                if (turmas && !turmas.erro) { turmas.forEach(t => { const opt = document.createElement('option'); opt.value = t.id; opt.textContent = t.nome + ' - ' + (t.serie || '—'); select.appendChild(opt); }); }
            }).catch(e => console.error(e));
        }

        function salvarConfiguracoes() { showToast('✅ Configurações salvas!', 'success'); }

        function carregarUserData() {
            console.log('🔄 Carregando dados do usuário...');
            try {
                const tbody = document.getElementById('u-tb-turmas');
                if (tbody) {
                    fetch(API_URL + '/api/turmas').then(r => r.json()).then(turmas => {
                        if (turmas && turmas.length > 0) {
                            tbody.innerHTML = turmas.map(t => {
                                const totalAlunos = t.total_alunos || 0;
                                return '<tr><td><strong>' + t.nome + '</strong></td><td><span class="badge badge-purple">' + (t.serie || '—') + '</span></td><td>' + (t.professor || '—') + '</td><td><span class="badge badge-blue">' + totalAlunos + '</span></td><td><button class="btn btn-green btn-sm" onclick="go(\'lista-turma\')">📋</button></td></tr>';
                            }).join('');
                        }
                    }).catch(e => console.error(e));
                }
            } catch (e) { console.log('Erro ao carregar dados do usuário:', e); }
        }

        // ============================================
        // DOM READY
        // ============================================
        document.addEventListener('DOMContentLoaded', function() {
            const tipoSelect = document.getElementById('modal-prova-tipo');
            if (tipoSelect) { tipoSelect.addEventListener('change', function() { gerarGabaritoModal(this.value); }); }
            buildGabGrid();
            carregarCombos();
            carregarDados();
            carregarFiltrosResultados();
            carregarResultadosComFiltros();
            carregarDesempenhoReal();
            carregarEscolasFiltroAlunos();
            const tipoProva = document.getElementById('modal-prova-tipo');
            if (tipoProva) gerarGabaritoModal(tipoProva.value);
        });

        document.getElementById('del-modal')?.addEventListener('click', e => { if (e.target === e.currentTarget) cancelarDel(); });

        window.addEventListener('resize', function() {
            if (window.innerWidth > 900) {
                const sidebar = document.getElementById('sidebar');
                const overlay = document.getElementById('menuOverlay');
                const toggle = document.getElementById('menuToggle');
                sidebar.classList.remove('open');
                overlay.classList.remove('show');
                toggle.classList.remove('active');
                toggle.innerHTML = '☰';
            }
        });
    </script>
</body>
</html>
