<!DOCTYPE html>
<html lang="pt-br">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Sistema de Matrícula Escolar</title>

<style>

body{
    font-family:Arial, Helvetica, sans-serif;
    background:#f4f6f9;
    margin:0;
}

header{
    background:#00b32d;
    color:white;
    padding:20px;
    text-align:center;
}

.container{
    width:95%;
    max-width:1200px;
    margin:auto;
    margin-top:20px;
}

.card{
    background:white;
    padding:20px;
    border-radius:10px;
    box-shadow:0px 0px 10px rgba(0,0,0,.15);
}

h2{
    color:#06b300;
}

label{
    font-weight:bold;
}

input,select{
    width:100%;
    padding:10px;
    margin-top:5px;
    margin-bottom:15px;
    border-radius:5px;
    border:1px solid #ccc;
}

button{
    padding:12px 20px;
    background:#00b36e;
    color:white;
    border:none;
    border-radius:5px;
    cursor:pointer;
}

button:hover{
    background:#00801c;
}

table{
    width:100%;
    border-collapse:collapse;
    margin-top:20px;
}

table th{
    background:hsl(162, 100%, 35%);
    color:white;
    padding:10px;
}

table td{
    border:1px solid #ccc;
    padding:8px;
}

</style>

</head>
<body>

<header>
<h1>SISTEMA DE MATRÍCULA ESCOLAR</h1>
<h1>E.M.E.I.F. "NOSSA SENHORA DE LOURDES"</h1>
</header>

<div class="container">

<div class="card">

<h2>Ficha de Matrícula</h2>

<label>Escola</label>
<input type="text" id="escola">

<label>Nome do Aluno(a)</label>
<input type="text" id="aluno">

<label>Idade</label>
<input type="text" id="idade">

<label>Turma</label>

<select id="turma">
<option>Maternal</option>
<option>Jardim I</option>
<option>Jardim II</option>
<option>1º Ano</option>
<option>2º Ano</option>
<option>3º Ano</option>
<option>4º Ano</option>
<option>5º Ano</option>
<option>6º Ano</option>
<option>7º Ano</option>
<option>8º Ano</option>
<option>9º Ano</option>
<option>EJA I</option>
<option>EJA II</option>
<option>EJA III</option>
<option>EJA IV</option>
</select>

<label>Nome do Responsável</label>
<input type="text" id="responsavel">

<label>Contato</label>
<input type="text" id="contato">

<label>Endereço</label>
<input type="text" id="endereco">

<label>Número de Matrícula</label>
<input type="text" id="matricula" readonly>

<button onclick="gerarMatricula()">Gerar Matrícula</button>

<button onclick="salvarAluno()">Salvar Matrícula</button>

<button onclick="exportarTurma()">Exportar Planilha da Turma</button>

</div>

<div class="card" style="margin-top:20px;">

<h2>Alunos Matriculados</h2>

<table id="tabela">

<thead>

<tr>

<th>Matrícula</th>

<th>Aluno</th>

<th>Turma</th>

<th>Responsável</th>

<th>Contato</th>

<th>Endereço</th>

</tr>

</thead>

<tbody>

</tbody>

</table>

</div>

</div>

<script>

let alunos=[];

function gerarMatricula(){

let numero="MAT"+Date.now();

document.getElementById("matricula").value=numero;

}

function salvarAluno(){

let escola=document.getElementById("escola").value;

let aluno=document.getElementById("aluno").value;

let turma=document.getElementById("turma").value;

let responsavel=document.getElementById("responsavel").value;

let contato=document.getElementById("contato").value;

let endereco=document.getElementById("endereco").value;

let matricula=document.getElementById("matricula").value;

if(aluno==""){

alert("Informe o nome do aluno.");

return;

}

let dados={

escola,

aluno,

turma,

responsavel,

contato,

endereco,

matricula

};

alunos.push(dados);

mostrarTabela();

limparCampos();

}

function mostrarTabela(){

let tbody=document.querySelector("#tabela tbody");

tbody.innerHTML="";

alunos.forEach(a=>{

tbody.innerHTML+=`

<tr>

<td>${a.matricula}</td>

<td>${a.aluno}</td>

<td>${a.turma}</td>

<td>${a.responsavel}</td>

<td>${a.contato}</td>

<td>${a.endereco}</td>

</tr>

`;

});

}

function limparCampos(){

document.getElementById("aluno").value="";

document.getElementById("responsavel").value="";

document.getElementById("contato").value="";

document.getElementById("endereco").value="";

document.getElementById("matricula").value="";

}

function exportarTurma(){

let turma=document.getElementById("turma").value;

let lista=alunos.filter(a=>a.turma==turma);

if(lista.length==0){

alert("Não existem alunos nesta turma.");

return;

}

let csv="ESCOLA;MATRICULA;ALUNO;TURMA;RESPONSAVEL;CONTATO;ENDERECO\n";

lista.forEach(a=>{

csv+=`${a.escola};${a.matricula};${a.aluno};${a.turma};${a.responsavel};${a.contato};${a.endereco}\n`;

});

let blob=new Blob([csv],{type:"text/csv;charset=utf-8;"});

let link=document.createElement("a");

link.href=URL.createObjectURL(blob);

link.download="Turma_"+turma+".csv";

link.click();

}

</script>

</body>
</html>
